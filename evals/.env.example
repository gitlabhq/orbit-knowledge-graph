# GitLab (both arms use the same instance)
# Token: set GITLAB_TOKEN, or authenticate via: glab auth login --hostname staging.gitlab.com
# The orbit_query.py tool and glab CLI both use PRIVATE-TOKEN header auth.
GITLAB_TOKEN=
GITLAB_HOST=staging.gitlab.com

# OpenCode (optional overrides)
OPENCODE_BASE_PORT=4096

# Model provider (used by OpenCode)
ANTHROPIC_API_KEY=
