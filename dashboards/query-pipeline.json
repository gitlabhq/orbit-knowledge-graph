{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Query rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(gkg_query_pipeline_queries_total{job=\"gkg-webserver\", query_type=~\"$query_type\"}[5m]) * 60)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "0",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "text", "value": null }] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value_and_name"
      },
      "description": "Queries per minute across all query types."
    },
    {
      "title": "Success rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(gkg_query_pipeline_queries_total{job=\"gkg-webserver\", status=\"ok\", query_type=~\"$query_type\"}[5m])) / clamp_min(sum(rate(gkg_query_pipeline_queries_total{job=\"gkg-webserver\", query_type=~\"$query_type\"}[5m])), 1)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "noValue": "100%",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.95 },
              { "color": "green", "value": 0.99 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value_and_name"
      },
      "description": "Percentage of queries that completed without error."
    },
    {
      "title": "CH rows read / min",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(gkg_query_pipeline_ch_read_rows_total{job=\"gkg-webserver\", query_type=~\"$query_type\"}[5m]) * 60)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "0",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "text", "value": null }] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value_and_name"
      },
      "description": "Total ClickHouse rows scanned per minute across all pipeline queries (base + hydration)."
    },
    {
      "title": "Pipeline duration (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": "Prometheus",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, sum by (le, query_type) (rate(gkg_query_pipeline_duration_seconds_bucket{job=\"gkg-webserver\", query_type=~\"$query_type\"}[5m])))",
          "legendFormat": "{{ query_type }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "showPoints": "auto" },
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi" }
      },
      "description": "End-to-end pipeline latency by query type (p95). Includes compilation, CH execution, authorization, and hydration."
    },
    {
      "title": "Stage breakdown (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": "Prometheus",
      "targets": [
        { "datasource": "Prometheus", "expr": "histogram_quantile(0.95, sum by (le) (rate(gkg_query_pipeline_compile_duration_seconds_bucket{job=\"gkg-webserver\", query_type=~\"$query_type\"}[5m])))", "legendFormat": "compile", "refId": "A" },
