        { "datasource": "Prometheus", "expr": "histogram_quantile(0.95, sum by (le) (rate(gkg_query_pipeline_hydration_duration_seconds_bucket{job=\"gkg-webserver\", query_type=~\"$query_type\"}[5m])))", "legendFormat": "hydration", "refId": "D" }
