    {
      "id": 2,
      "type": "stat",
      "title": "Queries / min",
      "description": "",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$ORBIT_DS"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "$ORBIT_DS"
          },
          "expr": "sum(rate(gkg_query_pipeline_queries_total{container=\"gkg-webserver\", cluster=~\"$cluster\"}[5m]) * 60)",
          "legendFormat": "qpm",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "\u2014"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value_and_name"
      }
    },
