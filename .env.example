# Lightweight native-process GKG dev cluster configuration
# Copy to .env and adjust ports if you need multiple isolated local clusters.

# GDK / upstream service connection
#
# Prerequisite: enable these native GDK services in gdk.yml:
#
#   nats:
#     enabled: true
#   clickhouse:
#     enabled: true
#   siphon:
#     enabled: true
#
GDK_ROOT=/home/you/workspace/gdk
GKG_NATS_URL=nats://localhost:4222
GKG_CLICKHOUSE_URL=http://127.0.0.1:8123
GKG_DATALAKE_DATABASE=gitlab_clickhouse_development
GKG_GRAPH_DATABASE=gkg-development
GKG_GITLAB_BASE_URL=http://127.0.0.1:3000
GKG_SIPHON_STREAM_NAME=siphon_stream_main_db

# Webserver instances
GKG_SERVER_PORT_1=8090
GKG_SERVER_GRPC_PORT_1=50054
GKG_SERVER_PORT_2=8091
GKG_SERVER_GRPC_PORT_2=50055

# Indexer health endpoints / identities
GKG_INDEXER_PORT_1=4202
GKG_INDEXER_PORT_2=4203
GKG_INDEXER_CONSUMER_1=gkg-indexer-1
GKG_INDEXER_CONSUMER_2=gkg-indexer-2

# Optional metrics ports (set GKG_ENABLE_METRICS=true to use)
GKG_ENABLE_METRICS=false
GKG_METRICS_PORT_1=9100
GKG_METRICS_PORT_2=9101
GKG_INDEXER_METRICS_PORT_1=9200
GKG_INDEXER_METRICS_PORT_2=9201
