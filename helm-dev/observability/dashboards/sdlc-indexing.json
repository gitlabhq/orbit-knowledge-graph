{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Pipeline Success Rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "1 - (sum(rate(indexer_sdlc_pipeline_errors_total{job=\"gkg-indexer\", entity=~\"$entity\"}[5m])) or vector(0)) / clamp_min(sum(rate(indexer_sdlc_pipeline_duration_seconds_count{job=\"gkg-indexer\", entity=~\"$entity\"}[5m])), 1)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "noValue": "100%",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.95 },
              { "color": "green", "value": 0.99 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value_and_name"
      },
      "description": "Percentage of pipeline runs that completed without error. Red < 95%, orange < 99%, green >= 99%."
    },
    {
      "title": "Rows / min",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(indexer_sdlc_pipeline_rows_processed_total{job=\"gkg-indexer\", entity=~\"$entity\"}[5m]) * 60)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "text", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value_and_name"
      },
      "description": "Total rows extracted and written per minute across all SDLC entity pipelines."
    },
    {
      "title": "Watermark Lag (max)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "max(indexer_sdlc_watermark_lag_seconds{job=\"gkg-indexer\", entity=~\"$entity\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "noValue": "0s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 300 },
              { "color": "red", "value": 900 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value_and_name"
      },
      "description": "Maximum delay between the latest watermark and wall clock time across all entities. Green < 5m, orange < 15m, red >= 15m. A growing lag means indexing is falling behind."
    },
    {
      "title": "Pipeline Duration by Entity (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": "Prometheus",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, sum by (le, entity) (rate(indexer_sdlc_pipeline_duration_seconds_bucket{job=\"gkg-indexer\", entity=~\"$entity\"}[5m])))",
          "legendFormat": "{{ entity }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "showPoints": "auto"
          },
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi" }
      },
      "description": "95th percentile pipeline duration per entity type. Identifies which entities are slowest to index."
    },
    {
      "title": "Rows Processed by Entity (rate/min)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": "Prometheus",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum by (entity) (rate(indexer_sdlc_pipeline_rows_processed_total{job=\"gkg-indexer\", entity=~\"$entity\"}[5m]) * 60)",
          "legendFormat": "{{ entity }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "showPoints": "auto"
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi" }
      },
      "description": "Rate of rows processed per minute by entity type. A drop to zero for a previously active entity signals a stalled pipeline."
    },
    {
      "title": "Datalake Query Latency by Entity (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": "Prometheus",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, sum by (le, entity) (rate(indexer_sdlc_datalake_query_duration_seconds_bucket{job=\"gkg-indexer\", entity=~\"$entity\"}[5m])))",
          "legendFormat": "{{ entity }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "showPoints": "auto"
          },
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi" }
      },
      "description": "95th percentile ClickHouse datalake extraction query time per entity. Rising latency here points to ClickHouse load or query complexity issues."
    },
    {
      "title": "Transform Latency by Entity (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": "Prometheus",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, sum by (le, entity) (rate(indexer_sdlc_transform_duration_seconds_bucket{job=\"gkg-indexer\", entity=~\"$entity\"}[5m])))",
          "legendFormat": "{{ entity }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "showPoints": "auto"
          },
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi" }
      },
      "description": "95th percentile DataFusion SQL transform time per entity. High values indicate expensive schema mappings or large batch sizes."
    },
    {
      "title": "Pipeline Errors by Entity",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "datasource": "Prometheus",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum by (entity, error_kind) (rate(indexer_sdlc_pipeline_errors_total{job=\"gkg-indexer\", entity=~\"$entity\"}[5m]) * 60)",
          "legendFormat": "{{ entity }} ({{ error_kind }})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "showPoints": "auto",
            "lineWidth": 2
          },
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi" }
      },
      "description": "Rate of pipeline failures per minute by entity. Sustained errors for one entity likely indicate a data schema mismatch or datalake query failure."
    },
    {
      "title": "Handler Duration (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 28 },
      "datasource": "Prometheus",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, sum by (le, handler) (rate(indexer_sdlc_handler_duration_seconds_bucket{job=\"gkg-indexer\"}[5m])))",
          "legendFormat": "{{ handler }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "showPoints": "auto"
          },
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi" }
      },
      "description": "95th percentile of full handler invocation time (global_handler vs namespace_handler). This is the wall-clock time for all pipelines in a single handler call."
    }
  ],
  "schemaVersion": 39,
  "tags": ["gkg", "sdlc-indexing"],
  "templating": {
    "list": [
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": "Prometheus",
        "definition": "label_values(indexer_sdlc_pipeline_duration_seconds_count{job=\"gkg-indexer\"}, entity)",
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "entity",
        "options": [],
        "query": "label_values(indexer_sdlc_pipeline_duration_seconds_count{job=\"gkg-indexer\"}, entity)",
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "SDLC Indexing",
  "uid": "sdlc-indexing",
  "version": 1
}
