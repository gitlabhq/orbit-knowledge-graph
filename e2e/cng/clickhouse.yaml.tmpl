# =============================================================================
# clickhouse.yaml.tmpl -- Standalone ClickHouse for E2E
#
# Rendered by template.rs from config/e2e.yaml values.
# Deployed BEFORE the GKG Helm chart so that:
#   1. ClickHouse is up and healthy
#   2. gitlab:clickhouse:migrate creates datalake tables + MVs + dictionaries
#   3. graph.sql creates GKG graph tables
#   4. THEN siphon + GKG start (data flows into pre-existing tables)
# =============================================================================
apiVersion: v1
kind: ConfigMap
metadata:
  name: ${INIT_CONFIGMAP}
  namespace: ${NAMESPACE}
data:
  init.sql: |
    CREATE DATABASE IF NOT EXISTS `${DATALAKE_DB}`;
    CREATE DATABASE IF NOT EXISTS `${GRAPH_DB}`;
---
apiVersion: v1
kind: Service
metadata:
  name: ${SERVICE_NAME}
  namespace: ${NAMESPACE}
spec:
  selector:
    app: ${SERVICE_NAME}
  ports:
    - name: http
      port: ${HTTP_PORT}
      targetPort: ${HTTP_PORT}
    - name: native
      port: ${NATIVE_PORT}
      targetPort: ${NATIVE_PORT}
---
apiVersion: apps/v1
kind: StatefulSet
metadata:
  name: ${SERVICE_NAME}
  namespace: ${NAMESPACE}
spec:
  serviceName: ${SERVICE_NAME}
  replicas: 1
  selector:
    matchLabels:
      app: ${SERVICE_NAME}
  template:
    metadata:
      labels:
        app: ${SERVICE_NAME}
    spec:
      enableServiceLinks: false
      containers:
        - name: clickhouse
          image: ${IMAGE}
          ports:
            - containerPort: ${HTTP_PORT}
              name: http
            - containerPort: ${NATIVE_PORT}
              name: native
          env:
            - name: CLICKHOUSE_USER
              value: ${CH_USER}
            - name: CLICKHOUSE_PASSWORD
              value: ""
            - name: CLICKHOUSE_DEFAULT_ACCESS_MANAGEMENT
              value: "1"
            - name: CLICKHOUSE_DB
              value: ${DATALAKE_DB}
          resources:
            requests:
              memory: 1Gi
              cpu: 100m
            limits:
              memory: 4Gi
              cpu: 1000m
          startupProbe:
            httpGet:
              path: /ping
              port: ${HTTP_PORT}
            failureThreshold: 30
            periodSeconds: 5
          livenessProbe:
            httpGet:
              path: /ping
              port: ${HTTP_PORT}
            periodSeconds: 30
          readinessProbe:
            httpGet:
              path: /ping
              port: ${HTTP_PORT}
            periodSeconds: 10
          volumeMounts:
            - name: data
              mountPath: /var/lib/clickhouse
            - name: init
              mountPath: /docker-entrypoint-initdb.d
      volumes:
        - name: init
          configMap:
            name: ${INIT_CONFIGMAP}
  volumeClaimTemplates:
    - metadata:
        name: data
      spec:
        accessModes: ["ReadWriteOnce"]
        resources:
          requests:
            storage: 5Gi
