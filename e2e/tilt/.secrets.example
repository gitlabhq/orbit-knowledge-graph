# E2E Tilt secrets
# Copy: cp e2e/tilt/.secrets.example e2e/tilt/.secrets
# Then fill in values from your GDK instance.

# JWT signing secret — must match GitLab's .gitlab_shell_secret
# Get it with: cat ~/Desktop/Code/gdk/gitlab/.gitlab_shell_secret
GKG_JWT_SECRET=

# ClickHouse password (leave empty if using default local setup)
CLICKHOUSE_PASSWORD=

# Postgres password for the siphon replication user
# Get it with: psql -h ~/Desktop/Code/gdk/postgresql -d gitlabhq_development -c "SELECT current_setting('password_encryption')"
# Usually empty for local GDK (trust auth)
POSTGRES_PASSWORD=
