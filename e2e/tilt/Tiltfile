# =============================================================================
# Tiltfile — E2E self-contained environment
#
# Spins up the GKG infrastructure stack inside k8s:
#   - ClickHouse (both datalake + graph databases)
#   - NATS
#   - Siphon producer (reads from Postgres)
#   - Siphon consumer (writes to in-cluster ClickHouse)
#   - GKG indexer + webserver
#
# Two modes:
#
#   GDK mode (default):
#     GitLab Rails runs on the host via GDK. Siphon reads from GDK's Postgres
#     at host.docker.internal. Tests run via `bundle exec rails runner` on host.
#
#   Caproni mode (GKG_E2E_CAPRONI=1):
#     GitLab Rails runs in-cluster (deployed by caproni). Siphon reads from the
#     in-cluster Postgres at gitlab-postgresql.gitlab.svc.cluster.local.
#     Tests run via `kubectl exec` into the toolbox pod.
#
# Usage:
#   # GDK mode:
#   cd ~/Desktop/Code/gkg
#   mise exec -- tilt up --file e2e/tilt/Tiltfile
#
#   # Caproni mode:
#   cd ~/Desktop/Code/gkg
#   GKG_E2E_CAPRONI=1 mise exec -- tilt up --file e2e/tilt/Tiltfile
#
# Prerequisites:
#   - Colima running with Kubernetes: colima start --kubernetes
#   - e2e/tilt/.secrets file exists (cp e2e/tilt/.secrets.example e2e/tilt/.secrets)
#   - GDK mode: GDK running with PostgreSQL + logical replication
#   - Caproni mode: `caproni up` + `post-deploy.sh` already completed
# =============================================================================

update_settings(k8s_upsert_timeout_secs=600)
ci_settings(readiness_timeout='10m')

allow_k8s_contexts(['colima', 'colima-caproni', 'docker-desktop', 'minikube', 'kind-kind', 'rancher-desktop'])

# ── Secrets ───────────────────────────────────────────────────────────────────

def load_secrets():
    secrets_file = '.secrets'
    if not os.path.exists(secrets_file):
        fail('''
Missing e2e/tilt/.secrets file. Create it with:

  cp e2e/tilt/.secrets.example e2e/tilt/.secrets

Then fill in GKG_JWT_SECRET from GDK:

  cat ~/Desktop/Code/gdk/gitlab/.gitlab_shell_secret
''')
    secrets = {}
    content = str(read_file('.secrets'))
    for line in content.strip().split('\n'):
        line = line.strip()
        if not line or line.startswith('#'):
            continue
        if '=' in line:
            key, value = line.split('=', 1)
            secrets[key.strip()] = value.strip()
    return secrets

secrets = load_secrets()

k8s_yaml(blob('''
apiVersion: v1
kind: Secret
metadata:
  name: postgres-credentials
type: Opaque
stringData:
  password: "{postgres_password}"
---
apiVersion: v1
kind: Secret
metadata:
  name: clickhouse-credentials
type: Opaque
stringData:
  password: "{clickhouse_password}"
---
apiVersion: v1
kind: Secret
metadata:
  name: gkg-server-credentials
type: Opaque
stringData:
  jwt-secret: "{jwt_secret}"
'''.format(
    postgres_password=secrets.get('POSTGRES_PASSWORD', ''),
    clickhouse_password=secrets.get('CLICKHOUSE_PASSWORD', ''),
    jwt_secret=secrets.get('GKG_JWT_SECRET', ''),
)))

# ── ClickHouse (in-cluster) ───────────────────────────────────────────────────
#
# A single ClickHouse instance serves both databases:
#   - gitlab_clickhouse_development  (datalake — Siphon writes here)
#   - gkg-development                (graph — GKG indexer writes here)
#
# An init ConfigMap creates both databases and applies the GKG graph schema on
# first startup.

clickhouse_init_sql = '''
CREATE DATABASE IF NOT EXISTS `gitlab_clickhouse_development`;
CREATE DATABASE IF NOT EXISTS `gkg-development`;
'''

k8s_yaml(blob('''
apiVersion: v1
kind: ConfigMap
metadata:
  name: gkg-e2e-clickhouse-init
data:
  init.sql: |
''' + '\n'.join(['    ' + line for line in clickhouse_init_sql.strip().split('\n')]) + '''
---
apiVersion: v1
kind: Service
metadata:
  name: gkg-e2e-clickhouse
spec:
  selector:
    app: gkg-e2e-clickhouse
  ports:
    - name: http
      port: 8123
      targetPort: 8123
    - name: native
      port: 9000
      targetPort: 9000
---
apiVersion: apps/v1
kind: StatefulSet
metadata:
  name: gkg-e2e-clickhouse
spec:
  serviceName: gkg-e2e-clickhouse
  replicas: 1
  selector:
    matchLabels:
      app: gkg-e2e-clickhouse
  template:
    metadata:
      labels:
        app: gkg-e2e-clickhouse
    spec:
      enableServiceLinks: false
      containers:
        - name: clickhouse
          image: clickhouse/clickhouse-server:25.1-alpine
          ports:
            - containerPort: 8123
              name: http
            - containerPort: 9000
              name: native
          env:
            - name: CLICKHOUSE_USER
              value: default
            - name: CLICKHOUSE_PASSWORD
              value: ""
            - name: CLICKHOUSE_DEFAULT_ACCESS_MANAGEMENT
              value: "1"
            - name: CLICKHOUSE_DB
              value: gitlab_clickhouse_development
          resources:
            requests:
              memory: 1Gi
              cpu: 100m
            limits:
              memory: 4Gi
              cpu: 1000m
          startupProbe:
            httpGet:
              path: /ping
              port: 8123
            failureThreshold: 30
            periodSeconds: 5
          livenessProbe:
            httpGet:
              path: /ping
              port: 8123
            periodSeconds: 30
          readinessProbe:
            httpGet:
              path: /ping
              port: 8123
            periodSeconds: 10
          volumeMounts:
            - name: data
              mountPath: /var/lib/clickhouse
            - name: init
              mountPath: /docker-entrypoint-initdb.d
      volumes:
        - name: init
          configMap:
            name: gkg-e2e-clickhouse-init
  volumeClaimTemplates:
    - metadata:
        name: data
      spec:
        accessModes: ["ReadWriteOnce"]
        resources:
          requests:
            storage: 5Gi
'''))

k8s_resource(
    'gkg-e2e-clickhouse',
    labels=['database'],
    port_forwards=['8124:8123'],  # exposed on host as :8124 to avoid clash with GDK's :8123
)

# ── GKG graph schema migration job ────────────────────────────────────────────
#
# The gkg-server modes (indexer, webserver, etc.) assume ClickHouse tables
# already exist. This Job applies the GKG graph schema only.
#
# Datalake tables (siphon_*) are created by GitLab's ClickHouse migrations
# (bundle exec rake gitlab:clickhouse:migrate), run from the toolbox pod in
# setup.sh — the same way GDK does it.
#
# Schema file:
#   - fixtures/schema/graph.sql  (graph tables: gl_user, gl_project, etc.)

graph_sql = str(read_file('../../fixtures/schema/graph.sql'))

k8s_yaml(blob('''
apiVersion: v1
kind: ConfigMap
metadata:
  name: gkg-e2e-schema
data:
  graph.sql: |
''' + '\n'.join(['    ' + line for line in graph_sql.strip().split('\n')]) + '''
---
apiVersion: batch/v1
kind: Job
metadata:
  name: gkg-e2e-migrate
  annotations:
    "helm.sh/hook-delete-policy": before-hook-creation
spec:
  template:
    spec:
      enableServiceLinks: false
      restartPolicy: OnFailure
      containers:
        - name: migrate
          image: clickhouse/clickhouse-server:25.1-alpine
          command: ["sh", "-c"]
          args:
            - |
              echo "Applying graph schema to gkg-development..."
              clickhouse-client --host gkg-e2e-clickhouse --user default --database gkg-development --multiquery < /schema/graph.sql
              echo "Graph schema migration complete."
          volumeMounts:
            - name: schema
              mountPath: /schema
      volumes:
        - name: schema
          configMap:
            name: gkg-e2e-schema
'''))

k8s_resource(
    'gkg-e2e-migrate',
    labels=['database'],
    resource_deps=['gkg-e2e-clickhouse'],
    trigger_mode=TRIGGER_MODE_MANUAL,
    auto_init=True,
)

# ── GKG server image (shared with main Tiltfile) ──────────────────────────────

custom_build(
    'gkg-server',
    'cd ../.. && scripts/build-dev.sh $EXPECTED_REF',
    deps=['../../crates/', '../../Cargo.toml', '../../Cargo.lock'],
)

# ── Helm dependencies ─────────────────────────────────────────────────────────

local('helm repo add nats https://nats-io.github.io/k8s/helm/charts/ 2>/dev/null || true', quiet=True)
local('helm dependency build ../../helm-dev/gkg 2>/dev/null', quiet=True)

# ── GKG chart (NATS + Siphon + GKG) ──────────────────────────────────────────

# Detect caproni mode: if set, overlay values-caproni.yaml to redirect
# Siphon to the in-cluster PostgreSQL instead of host.docker.internal.
caproni_mode = os.environ.get('GKG_E2E_CAPRONI', '') == '1'

values_files = ['./values.yaml']
if caproni_mode:
    values_files.append('./values-caproni.yaml')
    print('  Caproni mode: Siphon will read from in-cluster PostgreSQL')

k8s_yaml(helm(
    '../../helm-dev/gkg',
    name='gkg-e2e',
    namespace='default',
    values=values_files,
))

k8s_resource('gkg-indexer',    labels=['gkg'], resource_deps=['gkg-e2e-migrate'], pod_readiness='ignore')
k8s_resource('gkg-webserver',  labels=['gkg'], resource_deps=['gkg-e2e-migrate'], pod_readiness='ignore',
             port_forwards=['4200:8080', '50051:50051'])
k8s_resource('gkg-health-check', labels=['gkg'], pod_readiness='ignore',
             port_forwards=['4201:4201'])
k8s_resource('gkg-e2e-nats',      labels=['infrastructure'])
k8s_resource('siphon-producer',   labels=['siphon'], resource_deps=['gkg-e2e-nats'])
k8s_resource('siphon-consumer',   labels=['siphon'], resource_deps=['gkg-e2e-nats', 'gkg-e2e-clickhouse'])
