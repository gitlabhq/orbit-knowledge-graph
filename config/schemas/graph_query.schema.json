{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gitlab.com/gitlab-org/knowledge-graph/gkg-service",
  "title": "GraphQueryAsJSON",
  "description": "Schema for LLM-generated graph queries that compile to ClickHouse SQL",
  "type": "object",
  "required": ["query_type"],
  "properties": {
    "query_type": {
      "$ref": "#/$defs/QueryType"
    },
    "node": {
      "$ref": "#/$defs/NodeSelector",
      "description": "Single node selector"
    },
    "nodes": {
      "type": "array",
      "description": "Array of nodes for traversal, aggregation, path_finding queries",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "$ref": "#/$defs/NodeSelector"
      }
    },
    "relationships": {
      "type": "array",
      "description": "Relationships between nodes to traverse",
      "default": [],
      "maxItems": 5,
      "items": {
        "$ref": "#/$defs/RelationshipSelector"
      }
    },
    "aggregations": {
      "type": "array",
      "description": "Aggregation functions to apply. Required when query_type is 'aggregation'.",
      "default": [],
      "maxItems": 10,
      "items": {
        "$ref": "#/$defs/Aggregation"
      }
    },
    "path": {
      "$ref": "#/$defs/PathConfig",
      "description": "Path finding configuration. Required when query_type is 'path_finding'."
    },
    "neighbors": {
      "$ref": "#/$defs/NeighborsConfig",
      "description": "Neighbors configuration. Required when query_type is 'neighbors'."
    },
    "limit": {
      "type": "integer",
      "description": "Maximum number of results to return.",
      "minimum": 1,
      "maximum": 1000,
      "default": 30
    },
    "cursor": {
      "type": "object",
      "description": "Agent-driven pagination cursor. Slices the authorized result set (after redaction) by offset and page_size.",
      "required": ["offset", "page_size"],
      "properties": {
        "offset": {
          "type": "integer",
          "description": "0-based offset into the authorized (post-redaction) result set.",
          "minimum": 0,
          "maximum": 999
        },
        "page_size": {
          "type": "integer",
          "description": "Number of rows to return from the offset position. offset + page_size must not exceed limit.",
          "minimum": 1,
          "maximum": 100
        }
      },
      "additionalProperties": false
    },
    "order_by": {
      "$ref": "#/$defs/OrderBy",
      "description": "Result ordering specification"
    },
    "aggregation_sort": {
      "$ref": "#/$defs/AggregationSort",
      "description": "Ordering for aggregation outputs"
    },
    "options": {
      "$ref": "#/$defs/QueryOptions",
      "description": "Consumer-level preferences that affect result presentation, not query semantics."
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "query_type": { "const": "neighbors" }
        }
      },
      "then": {
        "required": ["node"],
        "not": {
          "required": ["nodes"]
        }
      },
      "else": {
        "oneOf": [
          {
            "required": ["nodes"],
            "not": { "required": ["node"] }
          },
          {
            "required": ["node"],
            "not": { "required": ["nodes"] },
            "description": "Single-node traversal: 1 node, 0 relationships"
          }
        ]
      }
    },
    {
      "if": {
        "properties": {
          "query_type": { "const": "neighbors" }
        }
      },
      "then": {
        "required": ["neighbors"]
      }
    },
    {
      "if": {
        "properties": {
          "query_type": { "const": "aggregation" }
        }
      },
      "then": {
        "required": ["aggregations"],
        "properties": {
          "aggregations": {
            "minItems": 1
          },
          "nodes": {
            "minItems": 1,
            "description": "Aggregation requires at least 1 node"
          },
          "relationships": {
            "items": {
              "properties": {
                "direction": {
                  "enum": ["outgoing", "incoming"],
                  "description": "Aggregation only supports outgoing or incoming direction."
                }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "query_type": { "const": "traversal" }
        }
      },
      "then": {
        "description": "Multi-node traversal requires nodes + relationships. Single-node traversal requires only a node.",
        "oneOf": [
          {
            "required": ["relationships"],
            "properties": {
              "nodes": {
                "minItems": 2,
                "description": "Multi-node traversal requires at least 2 nodes"
              },
              "relationships": {
                "minItems": 1,
                "description": "Multi-node traversal requires at least 1 relationship"
              }
            }
          },
          {
            "required": ["node"],
            "not": { "required": ["relationships"] },
            "description": "Single-node traversal (table scan)"
          }
        ]
      }
    },
    {
      "if": {
        "properties": {
          "query_type": { "const": "path_finding" }
        }
      },
      "then": {
        "required": ["path"],
        "properties": {
          "nodes": {
            "minItems": 2,
            "description": "Path finding requires at least 2 nodes (start and end)"
          }
        }
      }
    }
  ],
  "$defs": {
    "Identifier": {
      "type": "string",
      "description": "Safe SQL identifier: starts with letter/underscore, alphanumeric/underscore only, max 64 chars",
      "pattern": "^[a-zA-Z_][a-zA-Z0-9_]{0,63}$",
      "minLength": 1,
      "maxLength": 64
    },
    "QueryType": {
      "type": "string",
      "description": "Type of graph query to execute",
      "enum": ["traversal", "aggregation", "path_finding", "neighbors"]
    },
    "EntityType": {
      "type": "string",
      "description": "Valid entity types corresponding to GitLab data types (e.g., User, Project, MergeRequest). Validated against ontology at runtime.",
      "minLength": 1
    },
    "NodeProperties": {
      "type": "object",
      "description": "Property definitions per node label. Populated dynamically from ontology. Keys are entity names, values describe available properties.",
      "additionalProperties": {
        "type": "object",
        "description": "Properties available for a specific node label. Keys are property names, values are property schemas.",
        "additionalProperties": {
          "type": "object",
          "description": "Schema for a single property",
          "properties": {
            "type": {
              "type": "string",
              "description": "JSON Schema type of the property",
              "enum": ["string", "integer", "number", "boolean", "array", "object", "null"]
            },
            "description": {
              "type": "string",
              "description": "Human-readable description of the property"
            },
            "format": {
              "type": "string",
              "description": "Optional format hint (e.g., 'date-time', 'email', 'uri')"
            },
            "items": {
              "type": "object",
              "description": "For array types, describes the items"
            }
          }
        }
      }
    },
    "NodeSelector": {
      "type": "object",
      "description": "Selector for matching nodes in the graph",
      "required": ["id", "entity"],
      "properties": {
        "id": {
          "$ref": "#/$defs/Identifier",
          "description": "Variable identifier for this node (e.g., 'i', 'mr', 'user'). Used to reference this node in relationships and aggregations."
        },
        "entity": {
          "$ref": "#/$defs/EntityType",
          "description": "Entity type (e.g., User, Project, MergeRequest). Determines which table to query."
        },
        "columns": {
          "$ref": "#/$defs/ColumnSelection",
          "description": "Columns to return for this node. Use '*' for all columns, or specify an array of column names. If omitted, the node's default_columns from the ontology are returned. Mandatory columns (id, type) are always included for redaction."
        },
        "filters": {
          "type": "object",
          "description": "Property filters. Keys are property names, values are Filter objects. Limited to prevent query complexity explosion.",
          "propertyNames": {
            "$ref": "#/$defs/Identifier"
          },
          "additionalProperties": {
            "$ref": "#/$defs/Filter"
          },
          "maxProperties": 10,
          "default": {}
        },
        "node_ids": {
          "type": "array",
          "description": "Specific node IDs to filter by. Accepts integers or digit strings.",
          "items": {
            "oneOf": [
              { "type": "integer" },
              { "type": "string", "pattern": "^-?[0-9]+$", "maxLength": 20 }
            ]
          },
          "minItems": 1,
          "maxItems": 500
        },
        "id_range": {
          "$ref": "#/$defs/IdRange",
          "description": "ID range filter (inclusive)"
        },
        "id_property": {
          "$ref": "#/$defs/Identifier",
          "description": "Which property to use as ID (default: 'id')",
          "default": "id"
        }
      },
      "additionalProperties": false
    },
    "ColumnSelection": {
      "description": "Column selection for a node. Use '*' for all columns or an array of specific column names.",
      "oneOf": [
        {
          "const": "*",
          "description": "Select all columns for this entity"
        },
        {
          "type": "array",
          "description": "List of specific column names to select",
          "items": {
            "$ref": "#/$defs/Identifier"
          },
          "minItems": 1,
          "maxItems": 50
        }
      ]
    },
    "IdRange": {
      "type": "object",
      "description": "Inclusive ID range filter. Endpoints accept integers or digit strings.",
      "required": ["start", "end"],
      "properties": {
        "start": {
          "description": "Start of ID range (inclusive)",
          "oneOf": [
            { "type": "integer" },
            { "type": "string", "pattern": "^-?[0-9]+$", "maxLength": 20 }
          ]
        },
        "end": {
          "description": "End of ID range (inclusive)",
          "oneOf": [
            { "type": "integer" },
            { "type": "string", "pattern": "^-?[0-9]+$", "maxLength": 20 }
          ]
        }
      },
      "additionalProperties": false
    },
    "Filter": {
      "description": "Property filter - supports both simple equality and advanced operators",
      "oneOf": [
        {
          "$ref": "#/$defs/FilterValue",
          "description": "Simple equality filter (backward compatible)"
        },
        {
          "$ref": "#/$defs/PropertyFilter",
          "description": "Advanced operator-based filter"
        }
      ]
    },
    "FilterValue": {
      "description": "A filter value - can be a number (integer or float), string, boolean, or list",
      "oneOf": [
        {
          "type": "number",
          "description": "Numeric value (integer or floating-point)"
        },
        {
          "type": "string",
          "description": "String value",
          "maxLength": 1024
        },
        {
          "type": "boolean",
          "description": "Boolean value"
        },
        {
          "type": "array",
          "description": "List of values",
          "items": {
            "$ref": "#/$defs/FilterValue"
          },
          "maxItems": 100
        }
      ]
    },
    "PropertyFilter": {
      "type": "object",
      "description": "Advanced filter with operator",
      "required": ["op"],
      "properties": {
        "op": {
          "type": "string",
          "description": "Filter operator. Comparison: eq, gt, lt, gte, lte. Set membership: in (array value). Substring matching: contains, starts_with, ends_with. Nullability: is_null, is_not_null (no value). Word matching: token_match (exact word match), all_tokens (all words present), any_tokens (any word present) — only on fields that support word matching.",
          "enum": ["eq", "gt", "lt", "gte", "lte", "in", "contains", "starts_with", "ends_with", "is_null", "is_not_null", "token_match", "all_tokens", "any_tokens"]
        },
        "value": {
          "description": "Filter value. Required for all operators except is_null/is_not_null. Type: array for 'in', string for contains/starts_with/ends_with/token_match/all_tokens/any_tokens, scalar for comparison operators."
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": { "properties": { "op": { "enum": ["eq", "gt", "lt", "gte", "lte"] } } },
          "then": { "required": ["value"], "properties": { "value": { "$ref": "#/$defs/FilterValue" } } }
        },
        {
          "if": { "properties": { "op": { "const": "in" } } },
          "then": {
            "required": ["value"],
            "properties": {
              "value": {
                "type": "array",
                "items": { "$ref": "#/$defs/FilterValue" },
                "minItems": 1,
                "maxItems": 100
              }
            }
          }
        },
        {
          "if": { "properties": { "op": { "enum": ["contains", "starts_with", "ends_with"] } } },
          "then": { "required": ["value"], "properties": { "value": { "type": "string", "maxLength": 1024 } } }
        },
        {
          "if": { "properties": { "op": { "enum": ["token_match", "all_tokens", "any_tokens"] } } },
          "then": { "required": ["value"], "properties": { "value": { "type": "string", "maxLength": 1024 } } }
        }
      ]
    },
    "RelationshipSelector": {
      "type": "object",
      "description": "Selector for relationship traversal between nodes",
      "required": ["type", "from", "to"],
      "properties": {
        "type": {
          "$ref": "#/$defs/RelationshipType",
          "description": "Relationship type(s) to traverse"
        },
        "from": {
          "$ref": "#/$defs/Identifier",
          "description": "Source node variable ID (must match a node's id field)"
        },
        "to": {
          "$ref": "#/$defs/Identifier",
          "description": "Target node variable ID (must match a node's id field)"
        },
        "min_hops": {
          "type": "integer",
          "description": "Minimum number of relationship hops",
          "minimum": 0,
          "maximum": 3,
          "default": 1
        },
        "max_hops": {
          "type": "integer",
          "description": "Maximum number of relationship hops. Limited to prevent resource exhaustion.",
          "minimum": 1,
          "maximum": 3,
          "default": 1
        },
        "direction": {
          "$ref": "#/$defs/Direction",
          "description": "Direction to traverse the relationship",
          "default": "outgoing"
        },
        "filters": {
          "type": "object",
          "description": "Filters on relationship properties. Limited to prevent query complexity explosion.",
          "propertyNames": {
            "$ref": "#/$defs/Identifier"
          },
          "additionalProperties": {
            "$ref": "#/$defs/Filter"
          },
          "maxProperties": 5,
          "default": {}
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "description": "max_hops must be >= min_hops",
          "if": { "required": ["min_hops"], "properties": { "min_hops": { "minimum": 2 } } },
          "then": { "properties": { "max_hops": { "minimum": 2 } } }
        },
        {
          "if": { "required": ["min_hops"], "properties": { "min_hops": { "minimum": 3 } } },
          "then": { "properties": { "max_hops": { "minimum": 3 } } }
        }
      ]
    },
    "RelationshipType": {
      "description": "Relationship type specification - single, multiple, or wildcard",
      "oneOf": [
        {
          "$ref": "#/$defs/RelationshipTypeName",
          "description": "Single relationship type"
        },
        {
          "type": "array",
          "description": "Multiple relationship types (UNION ALL)",
          "items": {
            "$ref": "#/$defs/RelationshipTypeName"
          },
          "minItems": 1,
          "maxItems": 10
        }
      ]
    },
    "RelationshipTypeName": {
      "type": "string",
      "description": "Valid relationship type names. Validated against ontology at runtime.",
      "minLength": 1
    },
    "Direction": {
      "type": "string",
      "description": "Direction to traverse relationships. 'outgoing' follows from_table → to_table, 'incoming' reverses it.",
      "enum": ["outgoing", "incoming", "both"],
      "default": "outgoing"
    },
    "Aggregation": {
      "type": "object",
      "description": "Aggregation function specification",
      "required": ["function"],
      "properties": {
        "function": {
          "$ref": "#/$defs/AggFunction",
          "description": "Aggregation function to apply"
        },
        "target": {
          "$ref": "#/$defs/Identifier",
          "description": "Node variable to aggregate over. If omitted, aggregates all matching nodes."
        },
        "group_by": {
          "$ref": "#/$defs/Identifier",
          "description": "Node variable to group by. If omitted, no grouping is applied."
        },
        "property": {
          "$ref": "#/$defs/Identifier",
          "description": "Property to aggregate. Required for sum, avg, min, max functions."
        },
        "alias": {
          "$ref": "#/$defs/Identifier",
          "description": "Output column alias for the aggregation result"
        }
      },
      "additionalProperties": false,
      "if": {
        "properties": {
          "function": { "enum": ["sum", "avg", "min", "max"] }
        }
      },
      "then": {
        "required": ["property"]
      }
    },
    "AggFunction": {
      "type": "string",
      "description": "Available aggregation functions",
      "enum": ["count", "sum", "avg", "min", "max", "collect"]
    },
    "PathConfig": {
      "type": "object",
      "description": "Configuration for path finding queries",
      "required": ["type", "from", "to", "max_depth"],
      "properties": {
        "type": {
          "$ref": "#/$defs/PathType",
          "description": "Type of path finding algorithm"
        },
        "from": {
          "$ref": "#/$defs/Identifier",
          "description": "Source node variable ID"
        },
        "to": {
          "$ref": "#/$defs/Identifier",
          "description": "Target node variable ID"
        },
        "max_depth": {
          "type": "integer",
          "description": "Maximum path length (number of hops). SECURITY: Maximum 3 enforced.",
          "minimum": 1,
          "maximum": 3
        },
        "rel_types": {
          "type": "array",
          "description": "Relationship types to traverse. Required when an endpoint uses filters or id_range (not node_ids) to constrain the frontier. Optional when both endpoints use node_ids.",
          "items": {
            "$ref": "#/$defs/RelationshipTypeName"
          },
          "maxItems": 10
        }
      },
      "additionalProperties": false
    },
    "PathType": {
      "type": "string",
      "description": "Path finding algorithm type",
      "enum": ["shortest", "all_shortest", "any"]
    },
    "NeighborsConfig": {
      "type": "object",
      "description": "Configuration for neighbors queries",
      "required": ["node"],
      "properties": {
        "node": {
          "$ref": "#/$defs/Identifier",
          "description": "Node variable ID to find neighbors for"
        },
        "direction": {
          "$ref": "#/$defs/Direction",
          "description": "Direction to traverse relationships (outgoing, incoming, or both)",
          "default": "both"
        },
        "rel_types": {
          "type": "array",
          "description": "Optional: relationship types to traverse. If omitted, all types are considered.",
          "items": {
            "$ref": "#/$defs/RelationshipTypeName"
          },
          "maxItems": 10,
          "default": []
        }
      },
      "additionalProperties": false
    },
    "OrderBy": {
      "type": "object",
      "description": "Result ordering specification",
      "required": ["node", "property"],
      "properties": {
        "node": {
          "$ref": "#/$defs/Identifier",
          "description": "Node variable to order by"
        },
        "property": {
          "$ref": "#/$defs/Identifier",
          "description": "Property name to order by"
        },
        "direction": {
          "$ref": "#/$defs/OrderDirection",
          "description": "Sort direction",
          "default": "ASC"
        }
      },
      "additionalProperties": false
    },
    "AggregationSort": {
      "type": "object",
      "description": "Ordering for aggregation outputs",
      "required": ["agg_index"],
      "properties": {
        "agg_index": {
          "type": "integer",
          "description": "Index of the aggregation in the aggregations array (0-based)",
          "minimum": 0
        },
        "direction": {
          "$ref": "#/$defs/OrderDirection",
          "description": "Sort direction",
          "default": "ASC"
        }
      },
      "additionalProperties": false
    },
    "OrderDirection": {
      "type": "string",
      "description": "Sort direction",
      "enum": ["ASC", "DESC"],
      "default": "ASC"
    },
    "QueryOptions": {
      "type": "object",
      "description": "Consumer-level preferences that affect result presentation, not query semantics. Compiler performance options (skip_dedup, materialize_ctes, use_semi_join) are injected by the ontology-derived schema at runtime to keep the base schema token-efficient for LLM consumers.",
      "properties": {
        "dynamic_columns": {
          "$ref": "#/$defs/DynamicColumnMode",
          "description": "Columns fetched for dynamically-discovered entities (PathFinding, Neighbors hydration). '*' returns all columns; 'default' returns the entity's default_columns from the ontology. Defaults to 'default'.",
          "default": "default"
        },
        "include_debug_sql": {
          "type": "boolean",
          "description": "When true, includes compiled ClickHouse SQL in the response metadata for debugging. Only honored for authorized users (instance admins and direct GitLab org members with Reporter+ access). Defaults to false.",
          "default": false
        }
      }
    },
    "DynamicColumnMode": {
      "type": "string",
      "description": "Controls column selection for dynamically-discovered entities during hydration.",
      "enum": ["*", "default"],
      "default": "default"
    }
  }
}
