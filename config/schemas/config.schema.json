{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AppConfig",
  "type": "object",
  "properties": {
    "analytics": {
      "$ref": "#/$defs/AnalyticsConfig",
      "default": {
        "collector_url": "",
        "deployment": {
          "environment": "development",
          "type": "self_managed"
        },
        "enabled": false
      }
    },
    "billing": {
      "$ref": "#/$defs/BillingConfig",
      "default": {
        "collector_url": "",
        "enabled": false
      }
    },
    "bind_address": {
      "type": "string",
      "default": "127.0.0.1:4200"
    },
    "datalake": {
      "$ref": "#/$defs/ClickHouseConfiguration",
      "default": {
        "database": "default",
        "password": null,
        "profiling": {
          "enabled": false,
          "explain": false,
          "instance_health": false,
          "processors": false,
          "query_log": false
        },
        "query_settings": {},
        "url": "http://127.0.0.1:8123",
        "username": "default"
      }
    },
    "dispatcher_health_bind_address": {
      "type": "string",
      "default": "0.0.0.0:4203"
    },
    "engine": {
      "$ref": "#/$defs/EngineConfiguration",
      "default": {
        "concurrency_groups": {},
        "datalake_retry": {
          "halving_initial_block_size": 100000,
          "halving_min_block_size": 1024
        },
        "handlers": {
          "code-indexing-task": {
            "concurrency_group": null,
            "max_attempts": null,
            "pipeline": {
              "max_concurrent_languages": 0,
              "max_file_size_bytes": 5000000,
              "max_files": 1000000,
              "per_file_timeout_ms": 5000,
              "worker_threads": 0
            },
            "retry_interval_secs": null
          },
          "global-handler": {
            "batch_size_overrides": {},
            "concurrency_group": null,
            "datalake_batch_size": 1000000,
            "max_attempts": null,
            "retry_interval_secs": null
          },
          "namespace-deletion": {
            "concurrency_group": null,
            "max_attempts": null,
            "retry_interval_secs": null
          },
          "namespace-handler": {
            "batch_size_overrides": {},
            "concurrency_group": null,
            "datalake_batch_size": 1000000,
            "max_attempts": null,
            "max_concurrent_entities": 3,
            "retry_interval_secs": null
          }
        },
        "max_concurrent_workers": 16,
        "modules": [
          "sdlc",
          "code",
          "namespace_deletion"
        ]
      }
    },
    "gitlab": {
      "$ref": "#/$defs/GitlabConfig",
      "default": {
        "base_url": null,
        "jwt": {
          "signing_key": null,
          "verifying_key": null
        },
        "resolve_host": null
      }
    },
    "graph": {
      "$ref": "#/$defs/ClickHouseConfiguration",
      "default": {
        "database": "default",
        "password": null,
        "profiling": {
          "enabled": false,
          "explain": false,
          "instance_health": false,
          "processors": false,
          "query_log": false
        },
        "query_settings": {},
        "url": "http://127.0.0.1:8123",
        "username": "default"
      }
    },
    "grpc": {
      "$ref": "#/$defs/GrpcConfig",
      "default": {
        "concurrency_limit": 256,
        "connection_window_size": 2097152,
        "keepalive_interval_secs": 20,
        "keepalive_timeout_secs": 20,
        "max_connection_age_grace_secs": 30,
        "max_connection_age_secs": 300,
        "stream_timeout_secs": 60,
        "stream_window_size": 1048576,
        "tcp_keepalive_secs": 60
      }
    },
    "grpc_bind_address": {
      "type": "string",
      "default": "127.0.0.1:50054"
    },
    "health_check": {
      "$ref": "#/$defs/HealthCheckConfig",
      "default": {
        "bind_address": "0.0.0.0:4201",
        "targets": []
      }
    },
    "health_check_url": {
      "type": [
        "string",
        "null"
      ],
      "default": null
    },
    "indexer_health_bind_address": {
      "type": "string",
      "default": "0.0.0.0:4202"
    },
    "jwt_clock_skew_secs": {
      "type": "integer",
      "format": "uint64",
      "default": 60,
      "minimum": 0
    },
    "metrics": {
      "$ref": "#/$defs/MetricsConfig",
      "default": {
        "log_level": null,
        "otel": {
          "enabled": false,
          "endpoint": ""
        },
        "prometheus": {
          "enabled": false,
          "port": 9394
        }
      }
    },
    "nats": {
      "$ref": "#/$defs/NatsConfiguration",
      "default": {
        "ack_wait_secs": 300,
        "auto_create_streams": true,
        "batch_size": 10,
        "connection_timeout_secs": 10,
        "consumer_name": null,
        "fetch_expires_secs": 5,
        "max_deliver": 5,
        "password": null,
        "request_timeout_secs": 5,
        "stream_max_age_secs": 14400,
        "stream_max_bytes": null,
        "stream_max_messages": null,
        "stream_replicas": 1,
        "subscription_buffer_size": 100,
        "tls_ca_cert_path": null,
        "tls_cert_path": null,
        "tls_key_path": null,
        "url": "localhost:4222",
        "username": null
      }
    },
    "query": {
      "$ref": "#/$defs/QuerySettings",
      "default": {
        "default": {
          "max_execution_time": 30,
          "query_cache_ttl": 60
        }
      }
    },
    "schedule": {
      "$ref": "#/$defs/ScheduleConfig",
      "default": {
        "tasks": {
          "code-indexing-task": {
            "batch_size": 100,
            "cron": null,
            "events_stream_name": "siphon_stream_main_db"
          },
          "global": {
            "cron": null
          },
          "migration-completion": {
            "cron": "0 */5 * * * *"
          },
          "namespace": {
            "cron": null
          },
          "namespace-code-backfill": {
            "batch_size": 100,
            "cron": null,
            "events_stream_name": "siphon_stream_main_db"
          },
          "namespace-deletion": {
            "cron": "0 0 3 * * *"
          },
          "table-cleanup": {
            "cron": "0 0 3 * * *"
          }
        }
      }
    },
    "schema": {
      "$ref": "#/$defs/SchemaConfig",
      "default": {
        "max_retained_versions": 2,
        "version_poll_interval_secs": 5
      }
    },
    "tls": {
      "$ref": "#/$defs/TlsConfig",
      "default": {
        "cert_path": null,
        "key_path": null
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "AnalyticsConfig": {
      "type": "object",
      "properties": {
        "collector_url": {
          "type": "string",
          "default": ""
        },
        "deployment": {
          "$ref": "#/$defs/DeploymentConfig",
          "default": {
            "environment": "development",
            "type": "self_managed"
          }
        },
        "enabled": {
          "type": "boolean",
          "default": false
        }
      },
      "additionalProperties": false
    },
    "BillingConfig": {
      "type": "object",
      "properties": {
        "collector_url": {
          "type": "string",
          "default": ""
        },
        "enabled": {
          "type": "boolean",
          "default": false
        }
      },
      "additionalProperties": false
    },
    "ClickHouseConfiguration": {
      "type": "object",
      "properties": {
        "database": {
          "type": "string"
        },
        "password": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "profiling": {
          "$ref": "#/$defs/ProfilingConfig",
          "default": {
            "enabled": false,
            "explain": false,
            "instance_health": false,
            "processors": false,
            "query_log": false
          }
        },
        "query_settings": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "default": {}
        },
        "url": {
          "type": "string"
        },
        "username": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "required": [
        "database",
        "url",
        "username"
      ]
    },
    "CodeIndexingPipelineConfig": {
      "type": "object",
      "properties": {
        "max_concurrent_languages": {
          "type": "integer",
          "format": "uint",
          "default": 0,
          "minimum": 0
        },
        "max_file_size_bytes": {
          "type": "integer",
          "format": "uint64",
          "default": 5000000,
          "minimum": 0
        },
        "max_files": {
          "type": "integer",
          "format": "uint",
          "default": 1000000,
          "minimum": 0
        },
        "per_file_timeout_ms": {
          "description": "Global per-file resolution timeout in milliseconds.\nApplied to all languages unless the language's own DSL rules\nspecify a different value. 0 = no global timeout.",
          "type": "integer",
          "format": "uint64",
          "default": 5000,
          "minimum": 0
        },
        "worker_threads": {
          "type": "integer",
          "format": "uint",
          "default": 0,
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "CodeIndexingTaskHandlerConfig": {
      "description": "Per-handler engine configuration (retry policy, concurrency group).\n\nEach handler embeds this via `#[serde(flatten)]` in its own typed config struct.\nThe engine reads it via `handler.engine_config()`.\n\nRetries are opt-in: a handler with no retry config will ack on failure.",
      "type": "object",
      "properties": {
        "concurrency_group": {
          "description": "Which concurrency group this handler belongs to.\nMaps to a named semaphore in `EngineConfiguration::concurrency_groups`.",
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "max_attempts": {
          "description": "Maximum total attempts (including the first delivery) before giving up.\n\n`max_attempts: 1` means the handler runs once with no retries.\n`max_attempts: 5` means 1 initial attempt + 4 retries.\n\nWhen absent, failures are acked immediately (retries are opt-in).",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "default": null,
          "minimum": 0
        },
        "pipeline": {
          "$ref": "#/$defs/CodeIndexingPipelineConfig",
          "default": {
            "max_concurrent_languages": 0,
            "max_file_size_bytes": 5000000,
            "max_files": 1000000,
            "per_file_timeout_ms": 5000,
            "worker_threads": 0
          }
        },
        "retry_interval_secs": {
          "description": "Delay in seconds between retry attempts. Used as the NATS nack delay.\nWhen absent, nacks use immediate redelivery.",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "default": null,
          "minimum": 0
        }
      }
    },
    "DatalakeRetryConfig": {
      "description": "Tuning for the SDLC datalake extract retry loop.\n\nThe first attempt uses the datalake's configured `max_block_size`\n(typically `datalake_batch_size`). After a failure, subsequent attempts\nseed at `halving_initial_block_size` and halve on each retry, with\n`halving_min_block_size` as the floor.",
      "type": "object",
      "properties": {
        "halving_initial_block_size": {
          "description": "Starting `max_block_size` (in rows) for the halving series after the\nfirst failure. Sized to stay safely under the Arrow String int32\noffset cap even on unexpectedly heavy text columns.",
          "type": "integer",
          "format": "uint64",
          "default": 100000,
          "minimum": 0
        },
        "halving_min_block_size": {
          "description": "Floor for the halving series. Prevents pathologically tiny scans\nafter repeated retries.",
          "type": "integer",
          "format": "uint64",
          "default": 1024,
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "DeploymentConfig": {
      "type": "object",
      "properties": {
        "environment": {
          "$ref": "#/$defs/DeploymentEnvironment",
          "default": "development"
        },
        "type": {
          "$ref": "#/$defs/DeploymentKind",
          "default": "self_managed"
        }
      },
      "additionalProperties": false
    },
    "DeploymentEnvironment": {
      "type": "string",
      "enum": [
        "development",
        "staging",
        "production"
      ]
    },
    "DeploymentKind": {
      "type": "string",
      "enum": [
        "com",
        "dedicated",
        "self_managed"
      ]
    },
    "EngineConfiguration": {
      "description": "ETL engine configuration.\n\n# Defaults\n\n- `max_concurrent_workers`: 16\n- `concurrency_groups`: empty\n- `handlers`: defaults for all handlers\n- `modules`: all variants of [`IndexerModule`] (universal indexer)",
      "type": "object",
      "properties": {
        "concurrency_groups": {
          "description": "Named concurrency groups with their limits.\nHandlers reference these by name via `HandlerConfiguration::concurrency_group`.",
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "format": "uint",
            "minimum": 0
          },
          "default": {}
        },
        "datalake_retry": {
          "description": "Datalake retry tuning shared by all SDLC pipelines.",
          "$ref": "#/$defs/DatalakeRetryConfig",
          "default": {
            "halving_initial_block_size": 100000,
            "halving_min_block_size": 1024
          }
        },
        "handlers": {
          "description": "Per-handler configuration.",
          "$ref": "#/$defs/HandlersConfiguration",
          "default": {
            "code-indexing-task": {
              "concurrency_group": null,
              "max_attempts": null,
              "pipeline": {
                "max_concurrent_languages": 0,
                "max_file_size_bytes": 5000000,
                "max_files": 1000000,
                "per_file_timeout_ms": 5000,
                "worker_threads": 0
              },
              "retry_interval_secs": null
            },
            "global-handler": {
              "batch_size_overrides": {},
              "concurrency_group": null,
              "datalake_batch_size": 1000000,
              "max_attempts": null,
              "retry_interval_secs": null
            },
            "namespace-deletion": {
              "concurrency_group": null,
              "max_attempts": null,
              "retry_interval_secs": null
            },
            "namespace-handler": {
              "batch_size_overrides": {},
              "concurrency_group": null,
              "datalake_batch_size": 1000000,
              "max_attempts": null,
              "max_concurrent_entities": 3,
              "retry_interval_secs": null
            }
          }
        },
        "max_concurrent_workers": {
          "description": "Maximum concurrent message handlers across all modules. Defaults to 16.",
          "type": "integer",
          "format": "uint",
          "default": 16,
          "minimum": 0
        },
        "modules": {
          "description": "Modules whose handlers this indexer process should register. Defaults to all\nmodules for backward compatibility (universal indexer). Set to a subset to\nrun a specialised pool, e.g. `[code]` for a code-only Deployment.",
          "type": "array",
          "default": [
            "sdlc",
            "code",
            "namespace_deletion"
          ],
          "items": {
            "$ref": "#/$defs/IndexerModule"
          }
        }
      },
      "additionalProperties": false
    },
    "GitlabConfig": {
      "type": "object",
      "properties": {
        "base_url": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "jwt": {
          "$ref": "#/$defs/JwtConfig",
          "default": {
            "signing_key": null,
            "verifying_key": null
          }
        },
        "resolve_host": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        }
      },
      "additionalProperties": false
    },
    "GlobalDispatcherConfig": {
      "description": "Per-task schedule configuration.\n\nEach scheduled task embeds this via `#[serde(flatten)]` in its own typed config struct.\nThe scheduler reads it via `task.schedule()`.",
      "type": "object",
      "properties": {
        "cron": {
          "description": "Cron expression with seconds field (6-field: `sec min hour dom mon dow`).\nWhen absent, the task runs on a default 60-second interval.",
          "type": [
            "string",
            "null"
          ],
          "default": null
        }
      }
    },
    "GlobalHandlerConfig": {
      "description": "Per-handler engine configuration (retry policy, concurrency group).\n\nEach handler embeds this via `#[serde(flatten)]` in its own typed config struct.\nThe engine reads it via `handler.engine_config()`.\n\nRetries are opt-in: a handler with no retry config will ack on failure.",
      "type": "object",
      "properties": {
        "batch_size_overrides": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "format": "uint64",
            "minimum": 0
          },
          "default": {}
        },
        "concurrency_group": {
          "description": "Which concurrency group this handler belongs to.\nMaps to a named semaphore in `EngineConfiguration::concurrency_groups`.",
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "datalake_batch_size": {
          "type": "integer",
          "format": "uint64",
          "default": 1000000,
          "minimum": 0
        },
        "max_attempts": {
          "description": "Maximum total attempts (including the first delivery) before giving up.\n\n`max_attempts: 1` means the handler runs once with no retries.\n`max_attempts: 5` means 1 initial attempt + 4 retries.\n\nWhen absent, failures are acked immediately (retries are opt-in).",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "default": null,
          "minimum": 0
        },
        "retry_interval_secs": {
          "description": "Delay in seconds between retry attempts. Used as the NATS nack delay.\nWhen absent, nacks use immediate redelivery.",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "default": null,
          "minimum": 0
        }
      }
    },
    "GrpcConfig": {
      "type": "object",
      "properties": {
        "concurrency_limit": {
          "type": "integer",
          "format": "uint",
          "default": 256,
          "minimum": 0
        },
        "connection_window_size": {
          "type": "integer",
          "format": "uint32",
          "default": 2097152,
          "minimum": 0
        },
        "keepalive_interval_secs": {
          "type": "integer",
          "format": "uint64",
          "default": 20,
          "minimum": 0
        },
        "keepalive_timeout_secs": {
          "type": "integer",
          "format": "uint64",
          "default": 20,
          "minimum": 0
        },
        "max_connection_age_grace_secs": {
          "type": "integer",
          "format": "uint64",
          "default": 30,
          "minimum": 0
        },
        "max_connection_age_secs": {
          "type": "integer",
          "format": "uint64",
          "default": 300,
          "minimum": 0
        },
        "stream_timeout_secs": {
          "type": "integer",
          "format": "uint64",
          "default": 60,
          "minimum": 0
        },
        "stream_window_size": {
          "type": "integer",
          "format": "uint32",
          "default": 1048576,
          "minimum": 0
        },
        "tcp_keepalive_secs": {
          "type": "integer",
          "format": "uint64",
          "default": 60,
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "HandlersConfiguration": {
      "description": "Typed per-handler configuration for all registered handlers.",
      "type": "object",
      "properties": {
        "code-indexing-task": {
          "$ref": "#/$defs/CodeIndexingTaskHandlerConfig",
          "default": {
            "concurrency_group": null,
            "max_attempts": null,
            "pipeline": {
              "max_concurrent_languages": 0,
              "max_file_size_bytes": 5000000,
              "max_files": 1000000,
              "per_file_timeout_ms": 5000,
              "worker_threads": 0
            },
            "retry_interval_secs": null
          }
        },
        "global-handler": {
          "$ref": "#/$defs/GlobalHandlerConfig",
          "default": {
            "batch_size_overrides": {},
            "concurrency_group": null,
            "datalake_batch_size": 1000000,
            "max_attempts": null,
            "retry_interval_secs": null
          }
        },
        "namespace-deletion": {
          "$ref": "#/$defs/NamespaceDeletionHandlerConfig",
          "default": {
            "concurrency_group": null,
            "max_attempts": null,
            "retry_interval_secs": null
          }
        },
        "namespace-handler": {
          "$ref": "#/$defs/NamespaceHandlerConfig",
          "default": {
            "batch_size_overrides": {},
            "concurrency_group": null,
            "datalake_batch_size": 1000000,
            "max_attempts": null,
            "max_concurrent_entities": 3,
            "retry_interval_secs": null
          }
        }
      },
      "additionalProperties": false
    },
    "HealthCheckConfig": {
      "type": "object",
      "properties": {
        "bind_address": {
          "type": "string",
          "default": "0.0.0.0:4201"
        },
        "targets": {
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/NamespaceTarget"
          }
        }
      },
      "additionalProperties": false
    },
    "IndexerModule": {
      "description": "Indexer module selector. Each variant maps to a domain in `crates/indexer/src/modules/`.\n\nAn indexer process registers handlers only for the modules listed in\n[`EngineConfiguration::modules`], letting operators run multiple specialised\nindexer Deployments (e.g. a light SDLC pool and a beefy code pool) from the\nsame binary.",
      "oneOf": [
        {
          "description": "SDLC handlers: `global-handler` and `namespace-handler`.",
          "type": "string",
          "const": "sdlc"
        },
        {
          "description": "Code indexing handler: clones repositories, runs tree-sitter, writes the code graph.",
          "type": "string",
          "const": "code"
        },
        {
          "description": "Namespace deletion handler.",
          "type": "string",
          "const": "namespace_deletion"
        }
      ]
    },
    "JwtConfig": {
      "type": "object",
      "properties": {
        "signing_key": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "verifying_key": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        }
      },
      "additionalProperties": false
    },
    "MetricsConfig": {
      "type": "object",
      "properties": {
        "log_level": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "otel": {
          "$ref": "#/$defs/OtelConfig",
          "default": {
            "enabled": false,
            "endpoint": ""
          }
        },
        "prometheus": {
          "$ref": "#/$defs/PrometheusConfig",
          "default": {
            "enabled": false,
            "port": 9394
          }
        }
      },
      "additionalProperties": false
    },
    "MigrationCompletionConfig": {
      "description": "Per-task schedule configuration.\n\nEach scheduled task embeds this via `#[serde(flatten)]` in its own typed config struct.\nThe scheduler reads it via `task.schedule()`.",
      "type": "object",
      "properties": {
        "cron": {
          "description": "Cron expression with seconds field (6-field: `sec min hour dom mon dow`).\nWhen absent, the task runs on a default 60-second interval.",
          "type": [
            "string",
            "null"
          ],
          "default": null
        }
      }
    },
    "NamespaceCodeBackfillDispatcherConfig": {
      "description": "Per-task schedule configuration.\n\nEach scheduled task embeds this via `#[serde(flatten)]` in its own typed config struct.\nThe scheduler reads it via `task.schedule()`.",
      "type": "object",
      "properties": {
        "batch_size": {
          "type": "integer",
          "format": "uint",
          "default": 100,
          "minimum": 0
        },
        "cron": {
          "description": "Cron expression with seconds field (6-field: `sec min hour dom mon dow`).\nWhen absent, the task runs on a default 60-second interval.",
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "events_stream_name": {
          "type": "string",
          "default": "siphon_stream_main_db"
        }
      }
    },
    "NamespaceDeletionHandlerConfig": {
      "description": "Per-handler engine configuration (retry policy, concurrency group).\n\nEach handler embeds this via `#[serde(flatten)]` in its own typed config struct.\nThe engine reads it via `handler.engine_config()`.\n\nRetries are opt-in: a handler with no retry config will ack on failure.",
      "type": "object",
      "properties": {
        "concurrency_group": {
          "description": "Which concurrency group this handler belongs to.\nMaps to a named semaphore in `EngineConfiguration::concurrency_groups`.",
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "max_attempts": {
          "description": "Maximum total attempts (including the first delivery) before giving up.\n\n`max_attempts: 1` means the handler runs once with no retries.\n`max_attempts: 5` means 1 initial attempt + 4 retries.\n\nWhen absent, failures are acked immediately (retries are opt-in).",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "default": null,
          "minimum": 0
        },
        "retry_interval_secs": {
          "description": "Delay in seconds between retry attempts. Used as the NATS nack delay.\nWhen absent, nacks use immediate redelivery.",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "default": null,
          "minimum": 0
        }
      }
    },
    "NamespaceDeletionSchedulerConfig": {
      "description": "Per-task schedule configuration.\n\nEach scheduled task embeds this via `#[serde(flatten)]` in its own typed config struct.\nThe scheduler reads it via `task.schedule()`.",
      "type": "object",
      "properties": {
        "cron": {
          "description": "Cron expression with seconds field (6-field: `sec min hour dom mon dow`).\nWhen absent, the task runs on a default 60-second interval.",
          "type": [
            "string",
            "null"
          ],
          "default": null
        }
      }
    },
    "NamespaceDispatcherConfig": {
      "description": "Per-task schedule configuration.\n\nEach scheduled task embeds this via `#[serde(flatten)]` in its own typed config struct.\nThe scheduler reads it via `task.schedule()`.",
      "type": "object",
      "properties": {
        "cron": {
          "description": "Cron expression with seconds field (6-field: `sec min hour dom mon dow`).\nWhen absent, the task runs on a default 60-second interval.",
          "type": [
            "string",
            "null"
          ],
          "default": null
        }
      }
    },
    "NamespaceHandlerConfig": {
      "description": "Per-handler engine configuration (retry policy, concurrency group).\n\nEach handler embeds this via `#[serde(flatten)]` in its own typed config struct.\nThe engine reads it via `handler.engine_config()`.\n\nRetries are opt-in: a handler with no retry config will ack on failure.",
      "type": "object",
      "properties": {
        "batch_size_overrides": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "format": "uint64",
            "minimum": 0
          },
          "default": {}
        },
        "concurrency_group": {
          "description": "Which concurrency group this handler belongs to.\nMaps to a named semaphore in `EngineConfiguration::concurrency_groups`.",
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "datalake_batch_size": {
          "type": "integer",
          "format": "uint64",
          "default": 1000000,
          "minimum": 0
        },
        "max_attempts": {
          "description": "Maximum total attempts (including the first delivery) before giving up.\n\n`max_attempts: 1` means the handler runs once with no retries.\n`max_attempts: 5` means 1 initial attempt + 4 retries.\n\nWhen absent, failures are acked immediately (retries are opt-in).",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "default": null,
          "minimum": 0
        },
        "max_concurrent_entities": {
          "description": "Maximum number of entity pipelines (e.g. MergeRequest, Pipeline, Job)\nto run concurrently within a single namespace indexing pass.",
          "type": "integer",
          "format": "uint",
          "default": 3,
          "minimum": 0
        },
        "retry_interval_secs": {
          "description": "Delay in seconds between retry attempts. Used as the NATS nack delay.\nWhen absent, nacks use immediate redelivery.",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "default": null,
          "minimum": 0
        }
      }
    },
    "NamespaceTarget": {
      "description": "A namespace with lists of deployments and/or statefulsets to monitor.",
      "type": "object",
      "properties": {
        "deployments": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        },
        "namespace": {
          "type": "string"
        },
        "statefulSets": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false,
      "required": [
        "namespace"
      ]
    },
    "NatsConfiguration": {
      "description": "NATS connection settings.\n\nMatches siphon's QueuingConfig fields.",
      "type": "object",
      "properties": {
        "ack_wait_secs": {
          "description": "Acknowledgment wait time in seconds before message redelivery. Defaults to 300.",
          "type": "integer",
          "format": "uint64",
          "default": 300,
          "minimum": 0
        },
        "auto_create_streams": {
          "description": "Whether to auto-create streams on startup. Defaults to true.",
          "type": "boolean",
          "default": true
        },
        "batch_size": {
          "description": "How many messages to fetch per batch. Higher values improve throughput\nbut increase memory usage. Defaults to 10.",
          "type": "integer",
          "format": "uint",
          "default": 10,
          "minimum": 0
        },
        "connection_timeout_secs": {
          "description": "Connection timeout in seconds. Defaults to 10.",
          "type": "integer",
          "format": "uint64",
          "default": 10,
          "minimum": 0
        },
        "consumer_name": {
          "description": "Consumer name for durable subscriptions. Defaults to None (ephemeral consumer).\n\n**Ephemeral consumers** (`None`): Created on subscribe, destroyed on disconnect.\nMessages are only delivered while connected. Good for transient workers or testing.\n\n**Durable consumers** (`Some(\"name\")`): Persist across restarts. NATS tracks the\nlast acknowledged message, so reconnecting consumers resume where they left off.\nRequired for reliable message processing.\n\nFor horizontal scaling, give all instances the same `consumer_name`. NATS will\ndistribute messages across them (each message delivered to exactly one instance).",
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "fetch_expires_secs": {
          "description": "Server-side timeout in seconds for `consume_pending` batch fetch.\nMust be long enough for the NATS server to scan through gaps between\nmatching messages in filtered consumers. Defaults to 5.",
          "type": "integer",
          "format": "uint64",
          "default": 5,
          "minimum": 0
        },
        "max_deliver": {
          "description": "Maximum redelivery attempts. None means unlimited. Defaults to 5.",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "default": 5,
          "minimum": 0
        },
        "password": {
          "description": "Optional password for authentication.\nFor production, prefer environment variables over storing in config files.",
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "request_timeout_secs": {
          "description": "Request timeout in seconds. Defaults to 5.",
          "type": "integer",
          "format": "uint64",
          "default": 5,
          "minimum": 0
        },
        "stream_max_age_secs": {
          "description": "Maximum age of messages in seconds before deletion. Defaults to 14400 (4 hours).",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "default": 14400,
          "minimum": 0
        },
        "stream_max_bytes": {
          "description": "Maximum bytes per stream before oldest messages are deleted. Defaults to None (unlimited).",
          "type": [
            "integer",
            "null"
          ],
          "format": "int64",
          "default": null
        },
        "stream_max_messages": {
          "description": "Maximum messages per stream. Defaults to None (unlimited).",
          "type": [
            "integer",
            "null"
          ],
          "format": "int64",
          "default": null
        },
        "stream_replicas": {
          "description": "Number of stream replicas for fault tolerance. Defaults to 1.\nProduction should use 3 for fault tolerance.",
          "type": "integer",
          "format": "uint",
          "default": 1,
          "minimum": 0
        },
        "subscription_buffer_size": {
          "description": "How many messages to buffer per subscription. Defaults to 100.\n\nThis controls the capacity of the internal channel between the NATS fetch loop\nand your message handler. When `subscribe()` is called, a background task fetches\nmessages and queues them in this buffer.\n\n- **Smaller buffer**: Less memory, but the fetch loop may block waiting for the handler\n- **Larger buffer**: More messages pre-fetched, smoother throughput, higher memory usage\n\nFor slow handlers or bursty workloads, consider increasing this value.",
          "type": "integer",
          "format": "uint",
          "default": 100,
          "minimum": 0
        },
        "tls_ca_cert_path": {
          "description": "Path to CA certificate (PEM) for verifying the NATS server.\nSetting this enables TLS (connection uses `tls://` scheme).",
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "tls_cert_path": {
          "description": "Path to client certificate (PEM) for mTLS authentication.\nMust be paired with `tls_key_path`.",
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "tls_key_path": {
          "description": "Path to client private key (PEM) for mTLS authentication.\nMust be paired with `tls_cert_path`.",
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "url": {
          "description": "Server address, e.g. \"localhost:4222\".",
          "type": "string"
        },
        "username": {
          "description": "Optional username for authentication.",
          "type": [
            "string",
            "null"
          ],
          "default": null
        }
      },
      "additionalProperties": false,
      "required": [
        "url"
      ]
    },
