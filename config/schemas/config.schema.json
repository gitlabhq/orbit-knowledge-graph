        "max_rows_in_set": {
          "description": "ClickHouse `max_rows_in_set`. Limits the size of hash tables built\nfor IN (subquery) clauses. Unset by default.",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
        },
        "max_rows_to_read": {
          "description": "ClickHouse `max_rows_to_read`. Limits the total number of rows\nread from tables during query execution. Unset by default.",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
        },
        "query_cache_ttl": {
          "description": "ClickHouse `query_cache_ttl` in seconds.",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "default": 60,
          "minimum": 0
        },
        "use_query_cache": {
          "description": "ClickHouse `use_query_cache`. Enabled for cursor pagination.",
          "type": [
            "boolean",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "QuerySettings": {
      "description": "Top-level query settings loaded from YAML. Contains a `default` config\nand optional per-query-type overrides keyed by snake_case query type\nname (e.g. `traversal`, `aggregation`, `search`).\n\n```yaml\nquery:\n  default:\n    max_execution_time: 30\n    use_query_cache: false\n    query_cache_ttl: 60\n  aggregation:\n    max_execution_time: 60\n```",
      "type": "object",
      "properties": {
