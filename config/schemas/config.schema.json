        "max_memory_usage": {
          "description": "ClickHouse `max_memory_usage` in bytes. Limits the amount of RAM\na single query can consume on the ClickHouse server. When exceeded,\nClickHouse aborts the query with MEMORY_LIMIT_EXCEEDED. Unset by\ndefault (ClickHouse uses its server-level setting).",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
