SELECT
  '0/' AS traversal_path,
  ce.id AS id,
  ce.id AS source_id,
  cityHash64(concat(lowerUTF8(ai.identifier_type), '|', ai.identifier_value, '|', toString(ai.advisory_id), '|', toString(ai.position))) AS target_id,
  {{watermark_column}} AS _version,
  {{deleted_column}} AS _deleted
FROM siphon_pm_cve_enrichment AS ce FINAL
INNER JOIN siphon_pm_advisory_identifiers AS ai FINAL
  ON lowerUTF8(ai.identifier_type) = 'cve' AND ai.identifier_value = ce.cve
WHERE ce.{{deleted_column}} = FALSE AND ai.{{deleted_column}} = FALSE
  {{filters}}
ORDER BY id
LIMIT {{batch_size}}
