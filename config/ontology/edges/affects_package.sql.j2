SELECT
  '0/' AS traversal_path,
  ap.id AS id,
  ap.id AS source_id,
  p.id AS target_id,
  {{watermark_column}} AS _version,
  {{deleted_column}} AS _deleted
FROM siphon_pm_affected_packages FINAL ap
INNER JOIN siphon_pm_packages FINAL p
  ON p.purl_type = ap.purl_type AND p.name = ap.package_name
WHERE ap._siphon_deleted = FALSE AND p._siphon_deleted = FALSE
  {{filters}}
ORDER BY id
LIMIT {{batch_size}}
