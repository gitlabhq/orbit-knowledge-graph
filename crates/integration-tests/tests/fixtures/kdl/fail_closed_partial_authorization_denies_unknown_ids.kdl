test "fail_closed_partial_authorization_denies_unknown_ids" seed="default"

query """
  {
      "query_type": "search",
      "node": {"id": "u", "entity": "User"},
      "limit": 10
  }
"""

count raw=5

allow "user" 1 2

redact

count authorized=2 redacted=3
assert-ids authorized "u" 1 2
assert-ids denied "u" 3 4 5
