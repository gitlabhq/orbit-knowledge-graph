test "single_node_project_query_verifies_all_projects" seed="default"

query """
  {
      "query_type": "search",
      "node": {"id": "p", "entity": "Project"},
      "limit": 10
  }
"""

assert-ids raw "p" 1000 1001 1002 1003 1004

allow "project" 1000 1004

redact

assert-ids authorized "p" 1000 1004
assert-ids denied "p" 1001 1002 1003
