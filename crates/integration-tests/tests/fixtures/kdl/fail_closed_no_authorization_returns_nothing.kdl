test "fail_closed_no_authorization_returns_nothing" seed="default"

compile """
  {
      "query_type": "search",
      "node": {"id": "u", "entity": "User"},
      "limit": 10
  }
"""

execute

// Before redaction: all 5 users present.
raw-ids "u" 1 2 3 4 5

// No allow/deny rules — fail closed.
redact expect=5

authorized-count 0
