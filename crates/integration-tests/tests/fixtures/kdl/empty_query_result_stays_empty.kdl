test "empty_query_result_stays_empty" seed="default"

query """
  {
      "query_type": "search",
      "node": {"id": "u", "entity": "User", "filters": {"username": "nonexistent"}},
      "limit": 10
  }
"""

// Allow all users — but there are no rows to authorize.
redact allow "user" 1 2 3 4 5
redact run

assert-count authorized=0 redacted=0
