      "type": "AUTHORED",
      "from": "author",
      "to": "note"
    }
  ],
  "aggregations": [
    {
      "function": "count",
      "target": "note",
      "group_by": "author",
      "alias": "note_count"
    }
  ],
  "aggregation_sort": {
    "agg_index": 0,
    "direction": "DESC"
  },
  "limit": 20
}