{
  "query_type": "aggregation",
  "nodes": [
    {
      "id": "v",
      "entity": "Vulnerability",
      "filters": {
        "severity": {
          "op": "in",
          "value": [
            "high",
            "critical"
          ]
        },
        "state": {
          "op": "in",
          "value": [
            "detected",
            "confirmed"
          ]
        }
      }
    }
  ],
  "aggregations": [
    {
      "function": "count",
      "target": "v",
      "alias": "vuln_count"
    }
  ],
  "limit": 10
}