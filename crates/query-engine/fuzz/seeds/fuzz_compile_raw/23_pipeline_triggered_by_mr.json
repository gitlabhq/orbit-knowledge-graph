{
  "query_type": "traversal",
  "nodes": [
    {
      "id": "pipe",
      "entity": "Pipeline",
      "filters": {
        "source": "merge_request_event"
      }
    },
    {
      "id": "mr",
      "entity": "MergeRequest",
      "node_ids": "$sample"
    }
  ],
  "relationships": [
    {
      "type": "TRIGGERED",
      "from": "mr",
      "to": "pipe"
    }
  ],
  "limit": 10,
  "order_by": {
    "node": "pipe",
    "property": "created_at",
    "direction": "DESC"
  }
}