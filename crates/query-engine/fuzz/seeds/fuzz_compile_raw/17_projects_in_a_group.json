{
  "query_type": "traversal",
  "nodes": [
    {
      "id": "p",
      "entity": "Project",
      "filters": {
        "archived": false
      }
    },
    {
      "id": "g",
      "entity": "Group",
      "node_ids": "$sample"
    }
  ],
  "relationships": [
    {
      "type": "IN_GROUP",
      "from": "p",
      "to": "g"
    }
  ],
  "limit": 30,
  "order_by": {
    "node": "p",
    "property": "last_activity_at",
    "direction": "DESC"
  }
}