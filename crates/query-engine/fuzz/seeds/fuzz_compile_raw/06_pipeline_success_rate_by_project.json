{
  "query_type": "aggregation",
  "nodes": [
    {
      "id": "pipe",
      "entity": "Pipeline",
      "filters": {
        "status": {
          "op": "in",
          "value": [
            "success",
            "failed"
          ]
        }
      }
    },
    {
      "id": "p",
      "entity": "Project"
    }
  ],
  "relationships": [
    {
      "type": "IN_PROJECT",
      "from": "pipe",
      "to": "p"
    }
  ],
  "aggregations": [
    {
      "function": "count",
      "target": "pipe",
      "group_by": "p",
      "alias": "total_pipelines"
    }
  ],
  "limit": 20
}