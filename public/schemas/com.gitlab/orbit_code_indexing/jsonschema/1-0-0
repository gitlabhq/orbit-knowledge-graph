{
  "$schema": "http://iglucentral.com/schemas/com.snowplowanalytics.self-desc/schema/jsonschema/1-0-0#",
  "description": "Context for GKG code indexing events (gkg_indexing_completed for code data).",
  "self": {
    "vendor": "com.gitlab",
    "name": "orbit_code_indexing",
    "version": "1-0-0",
    "format": "jsonschema"
  },
  "type": "object",
  "additionalProperties": false,
  "required": ["project_id", "namespace_id", "root_namespace_id", "trigger_type"],
  "properties": {
    "project_id": {
      "description": "ID of the project being indexed.",
      "type": "integer",
      "minimum": 0,
      "maximum": 2147483647
    },
    "namespace_id": {
      "description": "ID of the namespace the project belongs to.",
      "type": "integer",
      "minimum": 0,
      "maximum": 2147483647
    },
    "root_namespace_id": {
      "description": "Top-level group of the project's namespace.",
      "type": "integer",
      "minimum": 0,
      "maximum": 2147483647
    },
    "branch": {
      "description": "Git branch that triggered the indexing. Null for scheduled or manual runs.",
      "type": ["string", "null"],
      "maxLength": 255
    },
    "commit_sha": {
      "description": "HEAD commit SHA at the time of indexing. Null for scheduled or manual runs.",
      "type": ["string", "null"],
      "maxLength": 64
    },
    "trigger_type": {
      "description": "What triggered the indexing run.",
      "type": "string",
      "enum": ["push", "scheduled", "manual"]
    }
  }
}
