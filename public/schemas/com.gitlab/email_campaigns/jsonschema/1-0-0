{
  "$schema": "http://iglucentral.com/schemas/com.snowplowanalytics.self-desc/schema/jsonschema/1-0-0#",
  "description": "Schema for a Gitlab email_campaigns event",
  "self": {
    "vendor": "com.gitlab",
    "name": "email_campaigns",
    "version": "1-0-0",
    "format": "jsonschema"
  },
  "type": "object",
  "additionalProperties": false,
  "required": ["namespace_id", "track", "series", "subject_line"],
  "properties": {
    "namespace_id": {
      "description": "Namespace ID",
      "type": "integer",
      "minimum": 0,
      "maximum": 2147483647
    },
    "track": {
      "description": "Track",
      "type": "string",
      "maxLength": 32
    },
    "series": {
      "description": "Series",
      "type": "integer",
      "minimum": 0,
      "maximum": 32
    },
    "subject_line": {
      "description": "Subject Line",
      "type": "string",
      "maxLength": 255
    }
  }
}
