{
  "$schema": "http://iglucentral.com/schemas/com.snowplowanalytics.self-desc/schema/jsonschema/1-0-0#",
  "description": "Schema for a Gitlab chat_question_categorization event",
  "self": {
    "vendor": "com.gitlab",
    "name": "ai_question_category",
    "version": "1-0-0",
    "format": "jsonschema"
  },
  "type": "object",
  "additionalProperties": false,
  "required": [
    "category",
    "detailed_category"
  ],
  "properties": {
    "category": {
      "description": "Main category of the question",
      "type": "string",
      "maxLength": 200
    },
    "detailed_category": {
        "description": "Detailed category of the question",
        "type": "string",
        "maxLength": 200
    }, 
    "contains_rejection": {
        "description": "",
        "type": ["boolean", "null"]
    }, 
    "contains_clarification": {
        "description": "",
        "type": ["boolean", "null"]
    }, 
    "contains_intellectual_property": {
        "description": "",
        "type": ["boolean", "null"]
    }, 
    "contains_credentials": {
        "description": "",
        "type": ["boolean", "null"]
    }, 
    "contains_code": {
        "description": "",
        "type": ["boolean", "null"]
    }, 
    "contains_personal_information": {
        "description": "",
        "type": ["boolean", "null"]
    }, 
    "compares_two_things": {
        "description": "",
        "type": ["boolean", "null"]
    }, 
    "compares_more_than_two_things": {
        "description": "",
        "type": ["boolean", "null"]
    },  
    "contains_request_to_format_the_answer": {
        "description": "",
        "type": ["boolean", "null"]
    }, 
    "is_related_to_gitlab": {
        "description": "",
        "type": ["boolean", "null"]
    }, 
    "is_related_to_devsecops": {
        "description": "",
        "type": ["boolean", "null"]
    }, 
    "is_follow_up_question": {
        "description": "",
        "type": ["boolean", "null"]
    }, 
    "language": {
        "description": "",
        "type": ["string", "null"],
        "maxLength": 200
    }, 
    "contains_link": {
        "description": "",
        "type": ["boolean", "null"]
    }, 
    "contains_link_to_issue": {
        "description": "",
        "type": ["boolean", "null"]
    }, 
    "contains_link_to_epic": {
        "description": "",
        "type": ["boolean", "null"]
    }, 
    "contains_link_to_pipeline": {
        "description": "",
        "type": ["boolean", "null"]
    }, 
    "contains_link_to_code": {
        "description": "",
        "type": ["boolean", "null"]
    }, 
    "is_proper_sentence": {
        "description": "",
        "type": ["boolean", "null"]
    }, 
    "number_of_questions_in_history": {
        "description": "",
        "type": ["integer", "null"],
        "minimum": 0,
        "maximum": 9223372036854775807
    },
    "length_of_questions_in_history": {
        "description": "",
        "type": ["integer", "null"],
        "minimum": 0,
        "maximum": 9223372036854775807
    },
    "time_since_last_question": {
        "description": "",
        "type": ["integer", "null"],
        "minimum": 0,
        "maximum": 9223372036854775807
    }, 
    "time_since_first_question": {
        "description": "",
        "type": ["integer", "null"],
        "minimum": 0,
        "maximum": 9223372036854775807
    }, 
    "asked_on_the_same_page": {
        "description": "",
        "type": ["boolean", "null"]
    }, 
    "length_of_questions": {
        "description": "",
        "type": ["integer", "null"],
        "minimum": 0,
        "maximum": 9223372036854775807
    }
  }
}
