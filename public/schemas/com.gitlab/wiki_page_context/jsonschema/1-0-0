{
  "$schema": "http://iglucentral.com/schemas/com.snowplowanalytics.self-desc/schema/jsonschema/1-0-0#",
  "description": "Schema for a wiki_page_context",
  "self": {
    "vendor": "com.gitlab",
    "name": "wiki_page_context",
    "version": "1-0-0",
    "format": "jsonschema"
  },
  "type": "object",
  "properties": {
    "wiki-format": {
      "description": "The format of the wiki page",
      "type": "string",
      "minLength": 1,
      "maxLength": 255
    },
    "wiki-title-size": {
      "description": "The size of the wiki page title in bytes, excluding any directories and the format extension",
      "type": "integer",
      "minimum": 0,
      "maximum": 2147483647
    },
    "wiki-content-size": {
      "description": "The size of the wiki page content in bytes",
      "type": "integer",
      "minimum": 0,
      "maximum": 9223372036854775807
    },
    "wiki-directory-nest-level": {
      "description": "The number of directories in the page's path",
      "type": "integer",
      "minimum": 0,
      "maximum": 2147483647
    }
  }
}

