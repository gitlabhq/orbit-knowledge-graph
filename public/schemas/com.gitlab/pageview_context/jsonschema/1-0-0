{
  "$schema": "http://iglucentral.com/schemas/com.snowplowanalytics.self-desc/schema/jsonschema/1-0-0#",
  "description": "Schema for a pageViewContext",
  "self": {
    "vendor": "com.gitlab",
    "name": "pageview_context",
    "version": "1-0-0",
    "format": "jsonschema"
  },
  "type": "object",
  "properties": {
    "page_type": {
      "description": "Controller path and action name",
      "type": "string",
      "maxLength": 50
    },
    "page_type_id": {
      "type": "integer",
      "description": "ID of the page controller object",
      "minimum": 0,
      "maximum": 2147483647
    },
    "namespace_id": {
      "type": "integer",
      "description": "ID of the namespace for the controller object",
      "minimum": 0,
      "maximum": 2147483647
    },
    "project_id": {
      "type": "integer",
      "description": "ID of the project for the controller object",
      "minimum": 0,
      "maximum": 2147483647
    }
  }
}
