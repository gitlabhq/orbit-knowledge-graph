{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "osvVulnerabilityAlerts": true,
  "packageRules": [
    {
      "description": "Unstable 0.x crates — require manual approval before MR is opened",
      "matchManagers": ["cargo"],
      "matchPackageNames": [
        "jsonschema",
        "opentelemetry*",
        "tracing-opentelemetry",
        "async-nats",
        "clickhouse"
      ],
      "dependencyDashboardApproval": true
    },
    {
      "description": "Group tonic/prost family into one MR, require manual approval",
      "matchManagers": ["cargo"],
      "matchPackageNames": [
        "tonic",
        "tonic-build",
        "tonic-prost",
        "tonic-prost-build",
        "prost",
        "prost-build",
        "prost-types"
      ],
      "groupName": "tonic/prost family",
      "dependencyDashboardApproval": true
    },
    {
      "description": "Group Arrow ecosystem into one MR, require manual approval",
      "matchManagers": ["cargo"],
      "matchPackageNames": [
        "arrow",
        "arrow-ipc",
        "parquet",
        "datafusion"
      ],
      "groupName": "Arrow ecosystem",
      "dependencyDashboardApproval": true
    }
  ]
}
