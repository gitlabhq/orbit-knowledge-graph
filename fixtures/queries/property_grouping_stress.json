{
  "security_vulnerability_001_by_severity": {
    "query_type": "aggregation",
    "nodes": [{"id": "v", "entity": "Vulnerability", "filters": {"state": {"op": "in", "value": ["detected", "confirmed", "resolved", "dismissed"]}}}],
    "group_by_properties": [{"node": "v", "property": "severity"}],
    "aggregations": [{"function": "count", "target": "v", "alias": "vulnerability_count"}],
    "aggregation_sort": {"agg_index": 0, "direction": "DESC"},
    "limit": 20
  },
