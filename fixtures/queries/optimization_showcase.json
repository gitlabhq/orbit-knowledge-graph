{
  "01_cascading_sip_3node_chain": {
    "query_type": "traversal",
    "nodes": [
      {"id": "u", "entity": "User", "node_ids": [1, 3, 5]},
      {"id": "mr", "entity": "MergeRequest", "filters": {"state": "merged"}},
      {"id": "p", "entity": "Project"}
    ],
    "relationships": [
      {"type": "AUTHORED", "from": "u", "to": "mr"},
      {"type": "IN_PROJECT", "from": "mr", "to": "p"}
    ],
    "limit": 50
  },

  "02_cascading_sip_4node_fan_out": {
    "query_type": "traversal",
    "nodes": [
      {"id": "p", "entity": "Project", "node_ids": [20699]},
      {"id": "mr", "entity": "MergeRequest", "filters": {"state": "merged"}},
      {"id": "author", "entity": "User"},
      {"id": "note", "entity": "Note"}
    ],
    "relationships": [
      {"type": "IN_PROJECT", "from": "mr", "to": "p"},
      {"type": "AUTHORED", "from": "author", "to": "mr"},
      {"type": "HAS_NOTE", "from": "mr", "to": "note"}
    ],
    "limit": 30
  },

  "03_neighbors_both_directions": {
    "query_type": "neighbors",
    "node": {"id": "mr", "entity": "MergeRequest", "node_ids": [9206503, 9605986, 9605991]},
    "neighbors": {"node": "mr", "direction": "both"},
    "limit": 100
  },

  "04_neighbors_outgoing_with_rel_filter": {
    "query_type": "neighbors",
    "node": {"id": "p", "entity": "Project", "node_ids": [13083]},
    "neighbors": {"node": "p", "direction": "outgoing", "rel_types": ["IN_PROJECT"]},
    "limit": 50
  },

  "05_path_finding_depth3": {
    "query_type": "path_finding",
    "nodes": [
      {"id": "start", "entity": "Project", "node_ids": [13083]},
      {"id": "end", "entity": "Project", "node_ids": [13764]}
    ],
    "path": {"type": "shortest", "from": "start", "to": "end", "max_depth": 3}
  },

  "06_path_finding_depth2_user_to_project": {
    "query_type": "path_finding",
    "nodes": [
      {"id": "start", "entity": "User", "node_ids": [1]},
      {"id": "end", "entity": "Project", "node_ids": [13083]}
    ],
    "path": {"type": "shortest", "from": "start", "to": "end", "max_depth": 2}
  },

  "07_aggregation_count_merged_mrs": {
    "query_type": "aggregation",
    "nodes": [
      {"id": "mr", "entity": "MergeRequest", "filters": {"state": "merged"}},
      {"id": "p", "entity": "Project", "columns": ["name"]}
    ],
    "relationships": [
      {"type": "IN_PROJECT", "from": "mr", "to": "p"}
    ],
    "aggregations": [
      {"function": "count", "target": "mr", "group_by": "p", "alias": "merged_mr_count"}
    ],
    "aggregation_sort": {"agg_index": 0, "direction": "DESC"},
    "limit": 20
  },

  "08_aggregation_sum_pipeline_duration": {
    "query_type": "aggregation",
    "nodes": [
      {"id": "pipe", "entity": "Pipeline", "filters": {"status": "success"}},
      {"id": "p", "entity": "Project", "columns": ["name"]}
    ],
    "relationships": [
      {"type": "IN_PROJECT", "from": "pipe", "to": "p"}
    ],
    "aggregations": [
      {"function": "sum", "target": "pipe", "property": "duration", "group_by": "p", "alias": "total_pipeline_seconds"}
    ],
    "aggregation_sort": {"agg_index": 0, "direction": "DESC"},
    "limit": 15
  },

  "09_cascading_sip_aggregation_mr_count_pinned": {
    "query_type": "aggregation",
    "nodes": [
      {"id": "p", "entity": "Project", "node_ids": [13083, 13764, 14022], "columns": ["name"]},
      {"id": "mr", "entity": "MergeRequest", "filters": {"state": "merged"}}
    ],
    "relationships": [
      {"type": "IN_PROJECT", "from": "mr", "to": "p"}
    ],
    "aggregations": [
      {"function": "count", "target": "mr", "group_by": "p", "alias": "merged_mr_count"}
    ],
    "aggregation_sort": {"agg_index": 0, "direction": "DESC"},
    "limit": 10
  },

  "10_traversal_user_to_group": {
    "query_type": "traversal",
    "nodes": [
      {"id": "u", "entity": "User", "node_ids": [1]},
      {"id": "g", "entity": "Group"}
    ],
    "relationships": [
      {"type": "MEMBER_OF", "from": "u", "to": "g"}
    ],
    "limit": 50
  },

  "11_traversal_project_pipelines_jobs": {
    "query_type": "traversal",
    "nodes": [
      {"id": "p", "entity": "Project", "node_ids": [13083]},
      {"id": "pipe", "entity": "Pipeline", "filters": {"status": "failed"}},
      {"id": "j", "entity": "Job", "filters": {"status": "failed"}}
    ],
    "relationships": [
      {"type": "IN_PROJECT", "from": "pipe", "to": "p"},
      {"type": "IN_PIPELINE", "from": "j", "to": "pipe"}
    ],
    "limit": 50
  }
}
