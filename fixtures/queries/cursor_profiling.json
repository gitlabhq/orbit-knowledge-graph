  "13_large_result_traversal_all_jobs_cursor": {
    "query_type": "traversal",
    "nodes": [
      {"id": "j", "entity": "Job"},
      {"id": "pipe", "entity": "Pipeline"}
    ],
    "relationships": [{"type": "IN_PIPELINE", "from": "j", "to": "pipe"}],
    "limit": 500,
    "cursor": {"offset": 0, "page_size": 50}
  },

  "14_aggregation_no_sort_cursor": {
    "query_type": "aggregation",
    "nodes": [
      {"id": "mr", "entity": "MergeRequest"},
      {"id": "p", "entity": "Project", "columns": ["name"]}
    ],
    "relationships": [{"type": "IN_PROJECT", "from": "mr", "to": "p"}],
    "aggregations": [{"function": "count", "target": "mr", "group_by": "p", "alias": "mr_count"}],
    "limit": 20,
    "cursor": {"offset": 0, "page_size": 5}
  },

  "15_path_finding_depth2_user_to_project": {
    "query_type": "path_finding",
    "nodes": [
      {"id": "start", "entity": "User", "node_ids": [1]},
