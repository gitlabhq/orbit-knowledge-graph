@startuml extraction_sequence
!theme plain
skinparam defaultFontName Helvetica
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true

skinparam participant {
    BackgroundColor #FFFFFF
    BorderColor #495057
}
skinparam actor {
    BackgroundColor #FFFFFF
}

title Extraction Sequence — Single Repository

actor "User / CI" as user
participant "CLI" as cli
participant "Orchestrator" as orch
participant "Phase 1 Skills\n(identity, technology)" as p1 <<parallel>>
participant "Phase 2 Skills\n(interfaces, deps,\ndeployment, data)" as p2 <<parallel>>
participant "synthesize-\narchitecture" as synth
participant "Claude API" as claude <<external>>
participant "File System" as fs

user -> cli : arch-extract extract <repo_path>
activate cli

cli -> orch : extract(repo_path, write_output=True)
activate orch

group Phase 1 — identity + technology (parallel)
    orch -> p1 : execute(repo_path)
    activate p1

    p1 -> fs : discover_files(repo_path)
    fs --> p1 : matched file paths

    p1 -> fs : read_files(paths)
    fs --> p1 : file contents

    p1 -> claude : messages.create(system_prompt, user_prompt\n+ file context + directory structure)
    activate claude
    claude --> p1 : JSON response
    deactivate claude

    p1 -> p1 : parse_json_response(raw_text)
    p1 --> orch : SkillResult(data, confidence, files_examined)
    deactivate p1
end

group Phase 2 — interfaces, deps, deployment, data (parallel, future)
    orch -> p2 : execute(repo_path)
    activate p2
    note over p2 : Not yet implemented —\nreturns empty SkillResults
    p2 --> orch : SkillResult(data={}, confidence=0)
    deactivate p2
end

group Phase 3 — synthesis (future)
    orch -> synth : execute(repo_path, prior_results)
    activate synth
    synth -> claude : messages.create(all skill outputs\nas context)
    activate claude
    claude --> synth : resolved component.json
    deactivate claude
    synth --> orch : SkillResult
    deactivate synth
end

orch -> orch : _merge_results(all_results)
note right : Builds canonical structure:\ncomponent, technology,\ninterfaces, dependencies,\ndeployment, data, metadata

orch -> orch : compute confidence\n(mean of skill confidences)

orch -> fs : write .architecture/component.json
fs --> orch : path

orch --> cli : component dict
deactivate orch

cli -> cli : validate against schema
cli --> user : summary\n(name, type, confidence\nper-section scores)
deactivate cli

@enduml
