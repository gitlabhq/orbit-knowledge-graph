{
  "$schema": "http://iglucentral.com/schemas/com.snowplowanalytics.self-desc/schema/jsonschema/1-0-0#",
  "description": "Schema for a Gitlab chat_question_categorization event",
  "self": {
    "vendor": "com.gitlab",
    "name": "ai_question_category",
    "version": "1-1-0",
    "format": "jsonschema"
  },
  "type": "object",
  "additionalProperties": false,
  "required": [
    "category",
    "detailed_category"
  ],
  "properties": {
    "category": {
      "description": "Main category of the question",
      "type": "string",
      "maxLength": 200
    },
    "detailed_category": {
        "description": "Detailed category of the question",
        "type": "string",
        "maxLength": 200
    }, 
    "contains_rejection": {
        "description": "User indicates that the answer they received is incorrect, incomplete, or unsatisfactory",
        "type": ["boolean", "null"]
    },
    "contains_rejection_previous_answer_incorrect": {
        "description": "User indicates that the answer they received is incorrect",
        "type": ["boolean", "null"]
    },
    "contains_rejection_previous_answer_incomplete": {
        "description": "User indicates that the answer they received is incomplete",
        "type": ["boolean", "null"]
    },
    "contains_rejection_previous_answer_unsatisfactory": {
        "description": "User indicates that the answer they received is unsatisfactory",
        "type": ["boolean", "null"]
    }, 
    "contains_clarification": {
        "description": "The user seems to not have understood the previous answer and asks a follow-up question to clarify this",
        "type": ["boolean", "null"]
    }, 
    "contains_intellectual_property": {
        "description": "User has input intellectual property such as copyrighted material, trademarks or company secrets",
        "type": ["boolean", "null"]
    }, 
    "contains_credentials": {
        "description": "User has input credentials such as usernames, passwords, tokens, and other things that can be used to authenticate to digital systems",
        "type": ["boolean", "null"]
    }, 
    "contains_code": {
        "description": "Question contains code written in a programming language",
        "type": ["boolean", "null"]
    }, 
    "contains_personal_information": {
        "description": "User has input personally identifiable information (PII) such as names, email addresses, phone numbers, or credit card numbers",
        "type": ["boolean", "null"]
    }, 
    "compares_two_things": {
        "description": "User has requested chat to compare two things against each other",
        "type": ["boolean", "null"]
    }, 
    "compares_more_than_two_things": {
        "description": "User has requested chat to compare two or more things against each other",
        "type": ["boolean", "null"]
    },  
    "requests_answer_in_certain_form": {
        "description": "User requests the chat to return the answer in a certain form, for example: short, long, bulleted list, containing a code snippet, formal, informal",
        "type": ["boolean", "null"]
    }, 
    "contains_request_to_format_the_answer": {
        "description": "User requests the chat to return the answer in a certain format, for example: XML, JSON, HTML, markdown",
        "type": ["boolean", "null"]
    }, 
    "is_related_to_gitlab": {
        "description": "User's question is related to GitLab, GitLab features, or how to use GitLab",
        "type": ["boolean", "null"]
    },
    "is_related_to_gitlab_data": {
        "description": "User's question is related to data in GitLab, such as the content of an issue, epic, code file, MR, or pipeline",
        "type": ["boolean", "null"]
    }, 
    "is_related_to_devsecops": {
        "description": "User's question relates to DevOps or DevSecOps, for example continuous integration and continuous deployment (CI/CD) pipelines, security testing tools, code scanning and review, threat modeling, security training for development teams, and automated compliance checks",
        "type": ["boolean", "null"]
    }, 
    "is_follow_up_question": {
        "description": "The user asks a follow-up question to seek additional information or clarification in response to a previous answer",
        "type": ["boolean", "null"]
    }, 
    "language": {
        "description": "The language code, e.g. en, fr, es",
        "type": ["string", "null"],
        "maxLength": 200
    }, 
    "contains_link": {
        "description": "The user has included a hyperlink in their question.",
        "type": ["boolean", "null"]
    }, 
    "contains_link_to_issue": {
        "description": "The user has included a hyperlink to a GitLab issue in their question.",
        "type": ["boolean", "null"]
    }, 
    "contains_link_to_epic": {
        "description": "The user has included a hyperlink to a GitLab epic in their question.",
        "type": ["boolean", "null"]
    }, 
    "contains_link_to_pipeline": {
        "description": "The user has included a hyperlink to a GitLab pipeline in their question.",
        "type": ["boolean", "null"]
    }, 
    "contains_link_to_code": {
        "description": "The user has included a hyperlink to code in GitLab in their question.",
        "type": ["boolean", "null"]
    }, 
    "is_proper_sentence": {
        "description": "",
        "type": ["boolean", "null"]
    }, 
    "is_poorly_formulated": {
        "description": "The user has composed a question that is poorly formulated and/or ambiguous",
        "type": ["boolean", "null"]
    },
    "first_question_after_reset": {
        "description": "is the first question after reset",
        "type": ["boolean", "null"]
    },
    "number_of_questions_in_history": {
        "description": "number of questions in history",
        "type": ["integer", "null"],
        "minimum": 0,
        "maximum": 9223372036854775807
    },
    "length_of_questions_in_history": {
        "description": "length of history in characters",
        "type": ["integer", "null"],
        "minimum": 0,
        "maximum": 9223372036854775807
    },
    "time_since_last_question": {
        "description": "time since last question (sec)",
        "type": ["integer", "null"],
        "minimum": 0,
        "maximum": 9223372036854775807
    }, 
    "time_since_first_question": {
        "description": "time since first question in history (sec)",
        "type": ["integer", "null"],
        "minimum": 0,
        "maximum": 9223372036854775807
    }, 
    "asked_on_the_same_page": {
        "description": "is asked on the same page as the previous question",
        "type": ["boolean", "null"]
    }, 
    "length_of_questions": {
        "description": "length of the question",
        "type": ["integer", "null"],
        "minimum": 0,
        "maximum": 9223372036854775807
    }
  }
}
