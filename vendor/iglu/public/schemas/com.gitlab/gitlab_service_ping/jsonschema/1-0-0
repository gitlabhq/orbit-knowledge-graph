{
  "$schema": "http://iglucentral.com/schemas/com.snowplowanalytics.self-desc/schema/jsonschema/1-0-0#",
  "description": "Schema for a Service Ping metrics migrated to Snowplow events",
  "self": {
    "vendor": "com.gitlab",
    "name": "gitlab_service_ping",
    "version": "1-0-0",
    "format": "jsonschema"
  },
  "type": "object",
  "additionalProperties": false,
  "required": ["data_source"],
  "anyOf" : [ 
    { 
      "required" : ["key_path"]
    },
    {
      "required" : ["event_name"]
    }
  ],
  "properties": {
    "data_source": {
      "description": "`data_source` attribute from metrics YAML definition",
      "type": "string",
      "maxLength": 64
    },
    "event_name": {
      "description": "When there is many to many relationship between events and metrics this field contains name of redis event that can be used for aggregations in downstream systems",
      "type": ["string", "null"],
      "maxLength": 128
    },
    "key_path": {
      "description": "`key_path` attribute from metrics YAML definition",
      "type": ["string", "null"],
      "maxLength": 256
    }
  }
}
