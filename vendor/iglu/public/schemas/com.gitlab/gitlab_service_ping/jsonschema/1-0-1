{
  "$schema": "http://iglucentral.com/schemas/com.snowplowanalytics.self-desc/schema/jsonschema/1-0-0#",
  "description": "Schema for a Service Ping metrics migrated to Snowplow events",
  "self": {
    "vendor": "com.gitlab",
    "name": "gitlab_service_ping",
    "version": "1-0-1",
    "format": "jsonschema"
  },
  "type": "object",
  "additionalProperties": false,
  "required": ["data_source", "event_name"],
  "properties": {
    "data_source": {
      "description": "`data_source` attribute from metrics YAML definition",
      "type": "string",
      "maxLength": 64
    },
    "event_name": {
      "description": "Name of the redis event (for Redis HLL/unique metrics) or the redis key (for Redis/total metrics)",
      "type": "string",
      "maxLength": 128
    }
  }
}
