{
  "$schema": "http://iglucentral.com/schemas/com.snowplowanalytics.self-desc/schema/jsonschema/1-0-0#",
  "description": "Schema for AI-specific context properties for DAP (Duo Agentic Platform) and AI Gateway events",
  "self": {
    "vendor": "com.gitlab",
    "name": "ai_context",
    "version": "1-0-1",
    "format": "jsonschema"
  },
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "session_id": {
      "description": "Session identifier from instance (not globally unique) - currently captured in event_value for many DAP events",
      "type": ["string", "integer", "null"],
      "maxLength": 255,
      "minimum": 0,
      "maximum": 2147483647
    },
    "workflow_id": {
      "description": "Globally unique session identifier: CONCAT(session_id, instance_id)",
      "type": ["string", "null"],
      "maxLength": 255
    },
    "flow_type": {
      "description": "Type of DAP flow (more custom flows to be included in the future)",
      "type": ["string", "null"],
      "maxLength": 64
    },
    "agent_name": {
      "description": "Which agent within the flow is executing",
      "type": ["string", "null"],
      "maxLength": 64
    },
    "agent_type": {
      "description": "Which agent type within the flow is executing",
      "type": ["string", "null"],
      "maxLength": 64
    },
    "input_tokens": {
      "description": "Tokens from user inputs",
      "type": ["integer", "null"],
      "minimum": 0,
      "maximum": 2147483647
    },
    "output_tokens": {
      "description": "Tokens generated by system",
      "type": ["integer", "null"],
      "minimum": 0,
      "maximum": 2147483647
    },
    "total_tokens": {
      "description": "Sum of input + output tokens",
      "type": ["integer", "null"],
      "minimum": 0,
      "maximum": 2147483647
    },
    "ephemeral_5m_input_tokens": {
      "description": "5-minute cached input tokens",
      "type": ["integer", "null"],
      "minimum": 0,
      "maximum": 2147483647
    },
    "ephemeral_1h_input_tokens": {
      "description": "1-hour cached input tokens",
      "type": ["integer", "null"],
      "minimum": 0,
      "maximum": 2147483647
    },
    "cache_read": {
      "description": "Cache read operations",
      "type": ["integer", "null"],
      "minimum": 0,
      "maximum": 2147483647
    },
    "cache_creation": {
      "description": "Number of tokens used to create the cache (Anthropic prompt caching)",
      "type": ["integer", "null"],
      "minimum": 0,
      "maximum": 2147483647
    },
    "model_engine": {
      "type": [
        "string",
        "null"
      ],
      "description": "Model engine used for the AI request",
      "maxLength": 64
    },
    "model_name": {
      "type": [
        "string",
        "null"
      ],
      "description": "Model name used for the AI request",
      "maxLength": 64
    },
    "model_provider": {
      "type": [
        "string",
        "null"
      ],
      "description": "Model provider used for the AI request",
      "maxLength": 64
    },
    "flow_version": {
      "description": "Version of the AI feature implementation for the flow",
      "type": ["string", "null"],
      "maxLength": 64
    },
    "flow_registry_version": {
      "description": "Flow Registry framework version used to build the flow",
      "type": ["string", "null"],
      "maxLength": 64
    }
  }
}
