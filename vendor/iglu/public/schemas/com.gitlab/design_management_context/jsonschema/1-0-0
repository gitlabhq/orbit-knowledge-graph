{
  "$schema": "http://iglucentral.com/schemas/com.snowplowanalytics.self-desc/schema/jsonschema/1-0-0#",
  "description": "Schema for a design_management_context",
  "self": {
    "vendor": "com.gitlab",
    "name": "design_management_context",
    "version": "1-0-0",
    "format": "jsonschema"
  },
  "type": "object",
  "properties": {
    "design-version-number": {
      "description": "The version of the currently viewed design",
      "type": "integer",
      "minimum": 0,
      "maximum": 9223372036854775807
    },
    "design-is-current-version": {
      "description": "Is the viewed design the latest version available of that particular design",
      "type": "boolean"
    },
    "internal-object-referrer": {
      "description": "Where the link to the design detail view comes from. e.g. Todo, Issue-design-collection",
      "type": "string",
      "minLength": 1,
      "maxLength": 255
    },
    "design-collection-owner": {
      "description": "Where the design collection lives. e.g. Issue ",
      "type": "string",
      "minLength": 1,
      "maxLength": 255
    }
  }
}

