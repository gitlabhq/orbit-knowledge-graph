{
  "$schema": "http://iglucentral.com/schemas/com.snowplowanalytics.self-desc/schema/jsonschema/1-0-0#",
  "description": "Schema for a secureContext",
  "self": {
    "vendor": "com.gitlab",
    "name": "secure_context",
    "version": "1-0-0",
    "format": "jsonschema"
  },
  "type": "object",
  "properties": {
    "data_sources": {
      "type": "integer",
      "description": "Number of distinct data sources involved in the vulnerability scan. For Container Scanning, this would be the number of different Docker images scanned. For Dependency Scanning, the number of different files scanned",
      "minimum": 0,
      "maximum": 2147483647
    },
    "pipeline_id": {
      "type": "integer",
      "description": "ID of the pipeline",
      "minimum": 0,
      "maximum": 2147483647
    },
    "merge_request_id": {
      "type": "integer",
      "description": "ID of the merge request",
      "minimum": 0,
      "maximum": 2147483647
    },
    "project_id": {
      "type": "integer",
      "description": "ID of the project",
      "minimum": 0,
      "maximum": 2147483647
    },
    "user_id": {
      "type": "integer",
      "description": "ID of the user that started the pipeline",
      "minimum": 0,
      "maximum": 2147483647
    },
    "scanner": {
      "type": "array",
      "description": "list of scanners used in pipeline",
      "items": {
        "type": "object",
        "description": "Details about the scanner that produced the list of vulnerabilities",
        "properties": {
          "type": {
            "type": "string",
            "maxLength": 50,
            "description": "Type of scanner that produced the list of vulnerabilities"
          },
          "id": {
            "type": "string",
            "maxLength": 50,
            "description": "ID of the scanner that produced the list of vulnerabilities"
          },
          "version": {
            "type": "string",
            "maxLength": 50,
            "description": "The version of the scanner"
          }
        }
      }
    },
    "branch_type": {
      "type": "string",
      "maxLength": 50,
      "description": "Type of branch associated with the vulnerabilities"
    },
    "vulnerabilities": {
      "type": "object",
      "description": "Details about vulnerabilities",
      "properties": {
        "diff": {
          "type": "object",
          "description": "Counts of the vulnerabilities that have been added, fixed or unchanged between two seperate vulnerability scans",
          "properties": {
            "added": {
              "type": "integer",
              "description": "Number of added vulnerabilities",
              "minimum": 0,
              "maximum": 2147483647
            },
            "fixed": {
              "type": "integer",
              "description": "Number of fixed vulnerabilities",
              "minimum": 0,
              "maximum": 2147483647
            },
            "existing": {
              "type": "integer",
              "description": "Number of existing vulnerabilities",
              "minimum": 0,
              "maximum": 2147483647
            }
          }
        },
        "severities_added": {
          "type": "object",
          "description": "Counts of the vulnerabilities with the given severity level values",
          "properties": {
            "critical": {
              "type": "integer",
              "description": "Number of vulnerabilities with severity level 'critical'",
              "minimum": 0,
              "maximum": 2147483647
            },
            "high": {
              "type": "integer",
              "description": "Number of vulnerabilities with severity level 'high'",
              "minimum": 0,
              "maximum": 2147483647
            },
            "medium": {
              "type": "integer",
              "description": "Number of vulnerabilities with severity level 'medium'",
              "minimum": 0,
              "maximum": 2147483647
            },
            "low": {
              "type": "integer",
              "description": "Number of vulnerabilities with severity level 'low'",
              "minimum": 0,
              "maximum": 2147483647
            },
            "info": {
              "type": "integer",
              "description": "Number of vulnerabilities with severity level 'info'",
              "minimum": 0,
              "maximum": 2147483647
            },
            "unknown": {
              "type": "integer",
              "description": "Number of vulnerabilities with severity level 'unknown'",
              "minimum": 0,
              "maximum": 2147483647
            }
          }
        }
      }
    }
  }
}
