{
  "$schema": "http://iglucentral.com/schemas/com.snowplowanalytics.self-desc/schema/jsonschema/1-0-0#",
  "description": "Context for GKG SDLC indexing events (gkg_indexing_completed for SDLC data).",
  "self": {
    "vendor": "com.gitlab",
    "name": "orbit_sdlc_indexing",
    "version": "1-0-0",
    "format": "jsonschema"
  },
  "type": "object",
  "additionalProperties": false,
  "required": ["namespace_id", "root_namespace_id"],
  "properties": {
    "namespace_id": {
      "description": "ID of the namespace being indexed.",
      "type": "integer",
      "minimum": 0,
      "maximum": 2147483647
    },
    "root_namespace_id": {
      "description": "Top-level group of the namespace being indexed.",
      "type": "integer",
      "minimum": 0,
      "maximum": 2147483647
    }
  }
}
